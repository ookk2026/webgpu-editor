<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WebGPU Editor - 完整版</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; height: 100%; overflow: hidden; font-family: system-ui, sans-serif; background: #0a0a0a; }
    #app { display: flex; flex-direction: column; width: 100%; height: 100%; }
    
    /* 工具栏 */
    #toolbar { height: 48px; background: #252526; border-bottom: 1px solid #333; display: flex; align-items: center; padding: 0 16px; gap: 8px; flex-shrink: 0; }
    #toolbar button { padding: 8px 14px; background: #3c3c3c; color: #e0e0e0; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; }
    #toolbar button:hover { background: #4c4c4c; }
    #toolbar button.primary { background: #0e639c; }
    #toolbar button.export { background: #28a745; }
    #toolbar button:disabled { opacity: 0.5; }
    #toolbar .separator { width: 1px; height: 24px; background: #444; margin: 0 4px; }
    
    /* 主布局 */
    #main { flex: 1; display: flex; overflow: hidden; align-items: stretch; }
    
    /* 左侧面板 */
    #left { width: 260px; background: #1e1e1e; border-right: 1px solid #333; display: flex; flex-direction: column; flex-shrink: 0; position: relative; }
    .tabs { display: flex; background: #252526; border-bottom: 1px solid #333; }
    .tab { flex: 1; padding: 10px; text-align: center; font-size: 11px; color: #888; cursor: pointer; border-bottom: 2px solid transparent; }
    .tab:hover { color: #ccc; }
    .tab.active { color: #0e639c; border-bottom-color: #0e639c; background: rgba(14,99,156,0.1); }
    .panel-content { flex: 1; overflow-y: auto; padding: 10px; }
    
    /* 场景树专用样式 */
    #panel-scene .panel-content {
      padding: 0;
    }
    #scene-tree {
      font-family: system-ui, -apple-system, sans-serif;
    }
    
    .preset-item { padding: 10px; margin-bottom: 8px; background: #252526; border: 1px solid #333; border-radius: 6px; cursor: pointer; }
    .preset-item:hover { border-color: #0e639c; }
    .preset-name { font-size: 12px; font-weight: 500; color: #ddd; }
    .preset-desc { font-size: 10px; color: #666; margin-top: 4px; }
    
    .tree-item { 
      padding: 6px 8px; 
      cursor: pointer; 
      border-radius: 4px; 
      display: flex; 
      align-items: center; 
      font-size: 12px; 
      color: #bbb; 
      margin-bottom: 1px; 
      white-space: nowrap; 
      overflow: hidden; 
      text-overflow: ellipsis;
      position: relative;
    }
    .tree-item:hover { background: rgba(255,255,255,0.05); }
    .tree-item.selected { background: rgba(14,99,156,0.3); color: #6cc4ff; }
    
    /* 树形展开按钮 */
    .tree-expand-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 14px;
      height: 14px;
      font-size: 10px;
      color: #666;
      cursor: pointer;
      border-radius: 2px;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    .tree-expand-btn:hover {
      background: rgba(255,255,255,0.1);
      color: #aaa;
    }
    .tree-expand {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 14px;
      height: 14px;
      font-size: 10px;
      color: #888;
      border-radius: 2px;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    .tree-expand:hover {
      background: rgba(255,255,255,0.1);
      color: #ccc;
    }
    
    /* 中间视口 */
    #center { flex: 1; position: relative; background: #050505; overflow: hidden; min-width: 200px; }
    #canvas { width: 100%; height: 100%; display: block; }
    #viewport-tools { position: absolute; top: 16px; left: 50%; transform: translateX(-50%); display: flex; gap: 6px; padding: 6px; background: rgba(37,37,38,0.9); border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); }
    #viewport-tools button { width: 36px; height: 36px; background: transparent; border: none; color: #ccc; cursor: pointer; border-radius: 6px; font-size: 16px; }
    #viewport-tools button:hover { background: rgba(255,255,255,0.1); color: #fff; }
    #viewport-tools button.active { background: #0e639c; color: #fff; }
    
    /* 右侧面板 */
    #right { width: 300px; background: #1e1e1e; border-left: 1px solid #333; display: flex; flex-direction: column; flex-shrink: 0; position: relative; }
    .prop-group { border-bottom: 1px solid #333; }
    .prop-group-header { 
      height: 32px; 
      background: #252526; 
      display: flex; 
      align-items: center; 
      padding: 0 12px; 
      font-size: 11px; 
      font-weight: 600; 
      color: #bbb; 
      text-transform: uppercase; 
      cursor: pointer;
      user-select: none;
      transition: background 0.2s;
    }
    .prop-group-header:hover { background: #2a2a2a; }
    .prop-group-header::before {
      content: '▼';
      display: inline-block;
      width: 14px;
      font-size: 10px;
      color: #666;
      transition: transform 0.2s;
    }
    .prop-group-header.collapsed::before {
      transform: rotate(-90deg);
    }
    .prop-group-content {
      max-height: 1000px;
      overflow: hidden;
      transition: max-height 0.3s ease-out, padding 0.3s;
    }
    .prop-group-content.collapsed {
      max-height: 0;
      padding-top: 0;
      padding-bottom: 0;
    }
    .prop-group-content { padding: 16px; }
    .prop-row { display: flex; align-items: center; margin-bottom: 12px; gap: 10px; }
    .prop-row:last-child { margin-bottom: 0; }
    .prop-label { width: 80px; color: #888; font-size: 11px; flex-shrink: 0; }
    .prop-input { flex: 1; display: flex; gap: 6px; }
    .prop-input input, .prop-input select { flex: 1; padding: 6px 10px; background: #3c3c3c; border: 1px solid #444; border-radius: 4px; color: #e0e0e0; font-size: 12px; font-family: inherit; }
    .prop-input input:focus { outline: none; border-color: #0e639c; }
    .prop-input input[type="color"] { width: 32px; height: 28px; padding: 2px; }
    .prop-input input[type="range"] { height: 4px; padding: 0; -webkit-appearance: none; background: #444; border-radius: 2px; }
    .prop-input input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 14px; height: 14px; background: #0e639c; border-radius: 50%; cursor: pointer; }
    .prop-value { min-width: 36px; text-align: right; font-size: 11px; color: #666; }
    .checkbox-row { display: flex; align-items: center; gap: 10px; cursor: pointer; color: #aaa; font-size: 12px; }
    .checkbox-row input { width: 16px; height: 16px; accent-color: #0e639c; }
    .btn-row { display: flex; gap: 8px; margin-top: 12px; }
    .btn-row button { flex: 1; padding: 10px; background: #0e639c; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; }
    .btn-row button:hover { background: #1177bb; }
    .btn-row button.secondary { background: #3c3c3c; }
    .btn-row button.danger { background: #dc3545; }
    
    /* 状态栏 */
    #statusbar { height: 28px; background: #007acc; display: flex; align-items: center; padding: 0 16px; font-size: 12px; color: #fff; flex-shrink: 0; }
    #statusbar span { margin-right: 24px; }
    
    /* 对话框 */
    .dialog-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.8); display: none; align-items: center; justify-content: center; z-index: 1000; }
    .dialog-overlay.active { display: flex; }
    .dialog { background: #1e1e1e; border: 1px solid #333; border-radius: 8px; width: 90%; max-width: 450px; }
    .dialog-header { padding: 16px 20px; border-bottom: 1px solid #333; font-size: 16px; font-weight: 600; color: #fff; display: flex; justify-content: space-between; align-items: center; }
    .dialog-close { background: none; border: none; color: #666; font-size: 24px; cursor: pointer; }
    .dialog-close:hover { color: #fff; }
    .dialog-body { padding: 20px; }
    
    /* 加载 */
    #loading { position: fixed; inset: 0; background: #0a0a0a; display: none; flex-direction: column; align-items: center; justify-content: center; color: #666; z-index: 9999; transition: opacity 0.5s; }
    #loading.hidden { opacity: 0; pointer-events: none; }
    .spinner { width: 50px; height: 50px; border: 3px solid #1a1a1a; border-top-color: #0e639c; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 16px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    
    .empty-state { padding: 40px 20px; text-align: center; color: #555; font-size: 12px; }
    
    /* 材质编辑器样式 */
    .mat-type-item { 
      padding: 8px 12px; 
      cursor: pointer; 
      font-size: 11px; 
      color: #aaa;
      transition: all 0.2s;
      border-left: 3px solid transparent;
    }
    .mat-type-item:hover { 
      background: #2a2a2a; 
      color: #fff;
    }
    .mat-type-item.selected { 
      background: rgba(14,99,156,0.2); 
      color: #6cc4ff;
      border-left-color: #0e639c;
    }
    
    .me-slot {
      padding: 8px 10px;
      background: #252526;
      border: 1px solid #333;
      border-radius: 4px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 10px;
      color: #888;
      transition: all 0.2s;
    }
    .me-slot:hover {
      border-color: #0e639c;
      background: #2a2a2a;
    }
    .me-slot.selected {
      border-color: #0e639c;
      background: rgba(14,99,156,0.15);
    }
    .me-slot .status {
      font-size: 9px;
      color: #666;
    }
    .me-slot.has-texture .status {
      color: #28a745;
    }
    
    /* 材质编辑器属性 */
    #mat-editor-properties input[type="range"] {
      width: 100%;
      height: 4px;
      -webkit-appearance: none;
      background: #444;
      border-radius: 2px;
      outline: none;
    }
    #mat-editor-properties input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 12px;
      height: 12px;
      background: #0e639c;
      border-radius: 50%;
      cursor: pointer;
    }
    
    /* 材质列表项 */
    .material-item { 
      padding: 10px; 
      background: #252526; 
      border: 1px solid #333; 
      border-radius: 6px; 
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: all 0.2s;
    }
    .material-item:hover { border-color: #0e639c; background: #2a2a2a; }
    .material-item.selected { border-color: #0e639c; background: rgba(14,99,156,0.2); }
    .material-preview { 
      width: 32px; 
      height: 32px; 
      border-radius: 4px; 
      border: 1px solid #444;
      background: #333;
    }
    .material-info { flex: 1; }
    .material-name { font-size: 12px; color: #ddd; font-weight: 500; }
    .material-type { font-size: 10px; color: #666; margin-top: 2px; }
    .material-actions { display: flex; gap: 4px; opacity: 0; transition: opacity 0.2s; }
    .material-item:hover .material-actions { opacity: 1; }
    .material-actions button { 
      padding: 4px 6px; 
      background: #3c3c3c; 
      border: none; 
      border-radius: 3px; 
      color: #aaa; 
      font-size: 10px; 
      cursor: pointer;
    }
    .material-actions button:hover { background: #dc3545; color: #fff; }
    
    /* 灯光列表项 */
    .light-item {
      padding: 10px;
      background: #252526;
      border: 1px solid #333;
      border-radius: 6px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: all 0.2s;
    }
    .light-item:hover { border-color: #ffc107; background: #2a2a2a; }
    .light-item.selected { border-color: #ffc107; background: rgba(255,193,7,0.15); }
    .light-icon { font-size: 16px; }
    .light-info { flex: 1; }
    .light-name { font-size: 12px; color: #ddd; font-weight: 500; }
    .light-type-label { font-size: 10px; color: #666; margin-top: 2px; }
    
    /* 右侧面板TAB */
    .right-tabs {
      display: flex;
      background: #252526;
      border-bottom: 1px solid #333;
      overflow-x: auto;
      flex-shrink: 0;
      user-select: none;
    }
    .right-tabs::-webkit-scrollbar {
      height: 3px;
    }
    .right-tabs::-webkit-scrollbar-thumb {
      background: #444;
    }
    .right-tab {
      padding: 10px 14px;
      font-size: 11px;
      color: #888;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
      white-space: nowrap;
      position: relative;
    }
    .right-tab:hover {
      color: #ccc;
      background: rgba(255,255,255,0.05);
    }
    .right-tab.active {
      color: #0e639c;
      border-bottom-color: #0e639c;
      background: rgba(14,99,156,0.1);
    }
    .right-tab.dragging {
      opacity: 0.5;
    }
    .right-tab.drag-over {
      background: rgba(14,99,156,0.2);
    }
    
    /* TAB内容面板 */
    .tab-panel {
      display: none;
      padding: 12px;
    }
    .tab-panel.active {
      display: block;
    }
    
    /* 拖拽条 */
    .resizer {
      width: 6px;
      cursor: col-resize;
      z-index: 100;
      transition: background 0.2s;
      background: rgba(255,255,255,0.05);
      flex-shrink: 0;
      align-self: stretch;
    }
    .resizer:hover, .resizer.active {
      background: #0e639c;
    }
    /* 拖拽条中间的指示线 */
    .resizer::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      height: 40px;
      width: 2px;
      background: rgba(255,255,255,0.15);
      border-radius: 1px;
      transition: background 0.2s;
    }
    .resizer:hover::after {
      background: rgba(255,255,255,0.5);
    }
    /* 拖拽时的遮罩层 */
    .resizing-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 9999;
      cursor: col-resize;
    }
  </style>
</head>
<body>
  <div id="app">
    <!-- 工具栏 -->
    <div id="toolbar">
      <button onclick="editor.newScene()">🗑 新建</button>
      <button id="btn-undo" onclick="editor.undo()" disabled>↶ 撤销</button>
      <button id="btn-redo" onclick="editor.redo()" disabled>↷ 重做</button>
      <div class="separator"></div>
      <button onclick="editor.addCube()" class="primary">⧉ 立方体</button>
      <button onclick="editor.addSphere()" class="primary">○ 球体</button>
      <button onclick="editor.addPhysicsBox()" class="primary">📦 物理</button>
      <button onclick="editor.addEmissive()" class="primary">✨ 发光</button>
      <button onclick="editor.addLight()" class="primary">💡 灯光</button>
      <div class="separator"></div>
      <button id="btn-select-mode" onclick="editor.toggleSelectMode()" style="background:#3c3c3c;font-size:11px;" title="切换选择模式">📦 选整体</button>
      <div style="flex:1"></div>
      <button id="btn-grid" onclick="editor.toggleGrid()" style="background:#3c3c3c;">⊞ 网格</button>
      <button onclick="editor.importModel()" style="background:#6c5ce7;">📁 导入</button>
      <button id="btn-physics" onclick="editor.togglePhysics()">⏸️ 暂停物理</button>
      <button onclick="editor.showExportDialog()" class="export">📦 导出</button>
    </div>

    <!-- 主区域 -->
    <div id="main">
      <!-- 左侧面板 -->
      <div id="left">
        <div class="tabs">
          <div class="tab active" onclick="switchTab('scene', this)">场景</div>
          <div class="tab" onclick="switchTab('mateditor', this)">材质</div>
          <div class="tab" onclick="switchTab('lights', this)">灯光</div>
          <div class="tab" onclick="switchTab('particles', this)">粒子</div>
          <div class="tab" onclick="switchTab('presets', this)">预设</div>
        </div>
        <div class="panel-content">
          <div id="panel-scene">
            <div id="scene-tree" class="empty-state">暂无对象</div>
          </div>
          
          <!-- 材质编辑器面板 (合并材质库) -->
          <div id="panel-mateditor" style="display:none;height:100%;">
            <div style="display:flex;flex-direction:column;height:100%;">
              <!-- 当前编辑对象信息 -->
              <div style="padding:8px;background:#252526;border-bottom:1px solid #333;">
                <div style="font-size:10px;color:#666;text-transform:uppercase;margin-bottom:2px;">当前编辑</div>
                <div id="mat-editor-target" style="font-size:11px;color:#ddd;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">未选择对象</div>
                <div id="mat-editor-target-type" style="font-size:9px;color:#888;margin-top:1px;"></div>
              </div>
              
              <!-- 主编辑区 -->
              <div style="flex:1;display:flex;overflow:hidden;">
                <!-- 左侧：材质库列表 -->
                <div style="width:100px;background:#1e1e1e;border-right:1px solid #333;overflow-y:auto;display:flex;flex-direction:column;flex-shrink:0;">
                  <div style="padding:6px;font-size:9px;color:#666;text-transform:uppercase;">材质库</div>
                  <div style="padding:0 6px 6px;">
                    <button onclick="editor.showCreateMaterialDialog()" style="width:100%;padding:4px;background:#0e639c;color:#fff;border:none;border-radius:3px;cursor:pointer;font-size:9px;">+ 新建</button>
                  </div>
                  <div id="mat-editor-library" style="flex:1;overflow-y:auto;padding:0 6px;">
                    <div style="font-size:10px;color:#666;padding:6px 0;">暂无材质</div>
                  </div>
                  
                  <div style="padding:6px;border-top:1px solid #333;">
                    <button onclick="editor.matEditorApplyToSelected()" style="width:100%;padding:4px;background:#28a745;color:#fff;border:none;border-radius:3px;cursor:pointer;font-size:9px;">✓ 应用</button>
                  </div>
                </div>
                
                <!-- 中间：预览和节点区 -->
                <div style="flex:1;display:flex;flex-direction:column;background:#252526;min-width:0;overflow:hidden;">
                  <!-- 预览区 -->
                  <div style="height:120px;background:#1a1a1a;border-bottom:1px solid #333;position:relative;flex-shrink:0;">
                    <canvas id="mat-preview-canvas" style="width:100%;height:100%;display:block;"></canvas>
                    <div style="position:absolute;top:4px;left:4px;font-size:9px;color:#666;">预览</div>
                  </div>
                  
                  <!-- 节点编辑区 -->
                  <div style="flex:1;position:relative;overflow:hidden;background:#2a2a2a;min-height:0;" id="mat-node-canvas-container">
                    <canvas id="mat-node-canvas" style="width:100%;height:100%;display:block;"></canvas>
                    <div style="position:absolute;top:4px;left:4px;display:flex;gap:2px;">
                      <button onclick="editor.matEditorAddNode('color')" style="padding:2px 6px;background:#3c3c3c;color:#fff;border:none;border-radius:2px;font-size:9px;cursor:pointer;">+颜色</button>
                      <button onclick="editor.matEditorAddNode('texture')" style="padding:2px 6px;background:#3c3c3c;color:#fff;border:none;border-radius:2px;font-size:9px;cursor:pointer;">+纹理</button>
                    </div>
                  </div>
                </div>
                
                <!-- 右侧：属性面板 -->
                <div style="width:130px;background:#1e1e1e;border-left:1px solid #333;overflow-y:auto;flex-shrink:0;">
                  <div style="padding:10px;font-size:11px;font-weight:600;color:#ddd;border-bottom:1px solid #333;">
                    材质属性
                  </div>
                  
                  <div id="mat-editor-properties" style="padding:10px;">
                    <!-- 基础颜色 -->
                    <div style="margin-bottom:12px;">
                      <div style="font-size:10px;color:#888;margin-bottom:4px;">基础颜色</div>
                      <div style="display:flex;gap:6px;align-items:center;">
                        <input type="color" id="me-color" value="#ffffff" oninput="editor.matEditorUpdateProp('color', this.value)" style="width:32px;height:24px;padding:0;border:none;">
                        <input type="text" id="me-color-hex" value="#ffffff" onchange="editor.matEditorUpdateProp('color', this.value)" style="flex:1;padding:4px 6px;background:#3c3c3c;border:1px solid #444;border-radius:3px;color:#ddd;font-size:11px;">
                      </div>
                    </div>
                    
                    <!-- 自发光 -->
                    <div style="margin-bottom:12px;">
                      <div style="font-size:10px;color:#888;margin-bottom:4px;">自发光</div>
                      <div style="display:flex;gap:6px;align-items:center;">
                        <input type="color" id="me-emissive" value="#000000" oninput="editor.matEditorUpdateProp('emissive', this.value)" style="width:32px;height:24px;padding:0;border:none;">
                        <input type="range" id="me-emissive-intensity" min="0" max="2" step="0.1" value="1" oninput="editor.matEditorUpdateProp('emissiveIntensity', this.value)" style="flex:1;height:4px;">
                      </div>
                    </div>
                    
                    <!-- 粗糙度 -->
                    <div style="margin-bottom:12px;">
                      <div style="display:flex;justify-content:space-between;font-size:10px;color:#888;margin-bottom:4px;">
                        <span>粗糙度</span>
                        <span id="me-val-roughness">0.5</span>
                      </div>
                      <input type="range" id="me-roughness" min="0" max="1" step="0.01" value="0.5" oninput="editor.matEditorUpdateProp('roughness', this.value)" style="width:100%;height:4px;">
                    </div>
                    
                    <!-- 金属度 -->
                    <div style="margin-bottom:12px;">
                      <div style="display:flex;justify-content:space-between;font-size:10px;color:#888;margin-bottom:4px;">
                        <span>金属度</span>
                        <span id="me-val-metalness">0.0</span>
                      </div>
                      <input type="range" id="me-metalness" min="0" max="1" step="0.01" value="0" oninput="editor.matEditorUpdateProp('metalness', this.value)" style="width:100%;height:4px;">
                    </div>
                    
                    <!-- 透明度 -->
                    <div style="margin-bottom:12px;">
                      <div style="display:flex;justify-content:space-between;font-size:10px;color:#888;margin-bottom:4px;">
                        <span>透明度</span>
                        <span id="me-val-opacity">1.0</span>
                      </div>
                      <input type="range" id="me-opacity" min="0" max="1" step="0.01" value="1" oninput="editor.matEditorUpdateProp('opacity', this.value)" style="width:100%;height:4px;">
                    </div>
                    
                    <!-- 双面渲染 -->
                    <div style="margin-bottom:12px;padding-top:12px;border-top:1px solid #333;">
                      <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:11px;color:#aaa;">
                        <input type="checkbox" id="me-side" onchange="editor.matEditorUpdateProp('side', this.checked ? 'double' : 'front')">
                        <span>双面渲染</span>
                      </label>
                    </div>
                    
                    <!-- 线框模式 -->
                    <div style="margin-bottom:12px;">
                      <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:11px;color:#aaa;">
                        <input type="checkbox" id="me-wireframe" onchange="editor.matEditorUpdateProp('wireframe', this.checked)">
                        <span>线框模式</span>
                      </label>
                    </div>
                  </div>
                  
                  <!-- 贴图槽 -->
                  <div style="padding:10px;border-top:1px solid #333;">
                    <div style="font-size:10px;color:#666;margin-bottom:8px;">贴图槽</div>
                    <div id="me-texture-slots" style="display:flex;flex-direction:column;gap:6px;">
                      <div class="me-slot" data-slot="map" onclick="editor.matEditorImportTexture('map')">
                        <span>🖼️ 颜色</span>
                        <span class="status">空</span>
                      </div>
                      <div class="me-slot" data-slot="normalMap" onclick="editor.matEditorImportTexture('normalMap')">
                        <span>⬆️ 法线</span>
                        <span class="status">空</span>
                      </div>
                      <div class="me-slot" data-slot="roughnessMap" onclick="editor.matEditorImportTexture('roughnessMap')">
                        <span>📊 粗糙度</span>
                        <span class="status">空</span>
                      </div>
                      <div class="me-slot" data-slot="metalnessMap" onclick="editor.matEditorImportTexture('metalnessMap')">
                        <span>⚙️ 金属度</span>
                        <span class="status">空</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- 灯光列表面板 -->
          <div id="panel-lights" style="display:none;">
            <div style="margin-bottom:8px;padding:8px;background:#1e3a1e;border-radius:6px;border:1px solid #2d5a2d;">
              <div style="font-size:11px;color:#7c7;">💡 提示: 点击3D视图中的灯光球体即可选中，或在下方列表中点击选择</div>
            </div>
            <div style="margin-bottom:12px;padding:8px;background:#252526;border-radius:6px;">
              <div style="font-size:10px;color:#666;margin-bottom:8px;text-transform:uppercase;">添加灯光</div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
                <button onclick="editor.createLight('point')" style="padding:8px;background:#3c3c3c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:4px;">
                  <span>💡</span><span>点光源</span>
                </button>
                <button onclick="editor.createLight('spot')" style="padding:8px;background:#3c3c3c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:4px;">
                  <span>🔦</span><span>聚光灯</span>
                </button>
                <button onclick="editor.createLight('directional')" style="padding:8px;background:#3c3c3c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:4px;">
                  <span>☀️</span><span>平行光</span>
                </button>
                <button onclick="editor.createLight('ambient')" style="padding:8px;background:#3c3c3c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:4px;">
                  <span>🌅</span><span>环境光</span>
                </button>
                <button onclick="editor.createLight('hemisphere')" style="padding:8px;background:#3c3c3c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:4px;">
                  <span>🌈</span><span>半球光</span>
                </button>
                <button onclick="editor.createLight('rect')" style="padding:8px;background:#3c3c3c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:4px;">
                  <span>⬜</span><span>矩形光</span>
                </button>
              </div>
            </div>
            <div id="light-list" style="display:flex;flex-direction:column;gap:6px;">
              <div class="empty-state">暂无灯光</div>
            </div>
          </div>
          
          <div id="panel-particles" style="display:none;">
            <div class="preset-item" onclick="editor.addParticle('fire')">
              <div class="preset-name">🔥 火焰</div>
              <div class="preset-desc">燃烧火焰效果</div>
            </div>
            <div class="preset-item" onclick="editor.addParticle('smoke')">
              <div class="preset-name">💨 烟雾</div>
              <div class="preset-desc">升腾烟雾</div>
            </div>
            <div class="preset-item" onclick="editor.addParticle('explosion')">
              <div class="preset-name">💥 爆炸</div>
              <div class="preset-desc">一次性爆发</div>
            </div>
            <div class="preset-item" onclick="editor.addParticle('magic')">
              <div class="preset-name">✨ 魔法</div>
              <div class="preset-desc">梦幻粒子</div>
            </div>
            <div class="preset-item" onclick="editor.addParticle('spark')">
              <div class="preset-name">⚡ 火花</div>
              <div class="preset-desc">四散火花</div>
            </div>
            <div class="preset-item" onclick="editor.addParticle('rain')">
              <div class="preset-name">🌧️ 雨滴</div>
              <div class="preset-desc">下雨效果</div>
            </div>
            <div class="btn-row">
              <button onclick="editor.burstParticles()">💥 爆发</button>
              <button class="danger" onclick="editor.clearParticles()">🗑 清除</button>
            </div>
          </div>
          <div id="panel-presets" style="display:none;">
            <div class="preset-item" onclick="editor.applyPreset('cinematic')">
              <div class="preset-name">🎬 电影级</div>
              <div class="preset-desc">高质量电影效果</div>
            </div>
            <div class="preset-item" onclick="editor.applyPreset('scifi')">
              <div class="preset-name">🚀 科幻</div>
              <div class="preset-desc">强烈霓虹辉光</div>
            </div>
            <div class="preset-item" onclick="editor.applyPreset('dreamy')">
              <div class="preset-name">💫 梦幻</div>
              <div class="preset-desc">柔和泛光</div>
            </div>
            <div class="preset-item" onclick="editor.applyPreset('performance')">
              <div class="preset-name">⚡ 性能优先</div>
              <div class="preset-desc">最佳帧率</div>
            </div>
            <div class="preset-item" onclick="editor.applyPreset('none')">
              <div class="preset-name">⏹️ 关闭效果</div>
              <div class="preset-desc">禁用所有后处理</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 左侧面板拖拽条 -->
      <div class="resizer" id="resizer-left"></div>

      <!-- 中间视口 -->
      <div id="center">
        <canvas id="canvas"></canvas>
        <div id="viewport-tools">
          <button id="tool-translate" class="active" onclick="editor.setTool('translate')">↔</button>
          <button id="tool-rotate" onclick="editor.setTool('rotate')">↻</button>
          <button id="tool-scale" onclick="editor.setTool('scale')">⤢</button>
          <button id="tool-local" onclick="editor.toggleSpace()">⊕</button>
        </div>
      </div>

      <!-- 右侧面板拖拽条 -->
      <div class="resizer" id="resizer-right"></div>

      <!-- 右侧面板 -->
      <div id="right">
        <!-- 可拖拽排序的TAB栏 -->
        <div id="right-tabs" class="right-tabs">
          <div class="right-tab active" data-tab="transform" draggable="true">变换</div>
          <div class="right-tab" data-tab="material" draggable="true">材质</div>
          <div class="right-tab" data-tab="light" draggable="true">灯光</div>
          <div class="right-tab" data-tab="physics" draggable="true">物理</div>
          <div class="right-tab" data-tab="bloom" draggable="true">辉光</div>
          <div class="right-tab" data-tab="stats" draggable="true">统计</div>
        </div>
        
        <!-- TAB内容区域 -->
        <div id="right-tab-content" style="flex:1;overflow-y:auto;position:relative;">
          
          <!-- 变换TAB -->
          <div id="tab-transform" class="tab-panel active">
            <div class="prop-group-content">
              <div class="prop-row">
                <span class="prop-label">位置</span>
                <div class="prop-input">
                  <input id="pos-x" type="number" step="0.1" onchange="editor.updateTransform()">
                  <input id="pos-y" type="number" step="0.1" onchange="editor.updateTransform()">
                  <input id="pos-z" type="number" step="0.1" onchange="editor.updateTransform()">
                </div>
              </div>
              <div class="prop-row">
                <span class="prop-label">旋转</span>
                <div class="prop-input">
                  <input id="rot-x" type="number" step="1" onchange="editor.updateTransform()">
                  <input id="rot-y" type="number" step="1" onchange="editor.updateTransform()">
                  <input id="rot-z" type="number" step="1" onchange="editor.updateTransform()">
                </div>
              </div>
              <div class="prop-row">
                <span class="prop-label">缩放</span>
                <div class="prop-input">
                  <input id="scale-x" type="number" step="0.1" value="1" onchange="editor.updateTransform()">
                  <input id="scale-y" type="number" step="0.1" value="1" onchange="editor.updateTransform()">
                  <input id="scale-z" type="number" step="0.1" value="1" onchange="editor.updateTransform()">
                </div>
              </div>
            </div>
            <!-- 对象信息显示 -->
            <div style="padding:12px 16px;border-top:1px solid #333;margin-top:8px;">
              <div style="font-size:10px;color:#666;margin-bottom:4px;">对象信息</div>
              <div id="obj-info-text" style="font-size:12px;color:#aaa;">未选择对象</div>
              <div id="obj-info-type" style="font-size:10px;color:#666;margin-top:4px;"></div>
            </div>
          </div>
          
          <!-- 材质TAB -->
          <div id="tab-material" class="tab-panel">
            <!-- 网格材质 (Mesh) -->
            <div id="props-mesh" style="display:none;">
              <div style="font-size:11px;color:#888;padding:8px 12px;border-bottom:1px solid #333;">网格材质</div>
              <div class="prop-group-content">
                <div class="prop-row">
                  <span class="prop-label">颜色</span>
                  <div class="prop-input">
                    <input id="mesh-mat-color" type="color" oninput="editor.updateMeshMaterial('color', this.value)">
                  </div>
                </div>
                <div class="prop-row">
                  <span class="prop-label">自发光</span>
                  <div class="prop-input">
                    <input id="mesh-mat-emissive" type="color" oninput="editor.updateMeshMaterial('emissive', this.value)">
                  </div>
                </div>
                <div class="prop-row">
                  <span class="prop-label">粗糙度</span>
                  <input id="mesh-mat-roughness" type="range" min="0" max="1" step="0.01" oninput="editor.updateMeshMaterial('roughness', this.value)">
                  <span class="prop-value" id="mesh-val-roughness">0.5</span>
                </div>
                <div class="prop-row">
                  <span class="prop-label">金属度</span>
                  <input id="mesh-mat-metalness" type="range" min="0" max="1" step="0.01" oninput="editor.updateMeshMaterial('metalness', this.value)">
                  <span class="prop-value" id="mesh-val-metalness">0</span>
                </div>
              </div>
            </div>
            
            <!-- 模型材质 -->
            <div id="props-model" style="display:none;">
              <div style="font-size:11px;color:#888;padding:8px 12px;border-bottom:1px solid #333;">模型材质</div>
              <div id="model-mat-list" style="max-height:120px;overflow-y:auto;border-bottom:1px solid #333;"></div>
              <div class="prop-group-content">
                <div class="prop-row">
                  <span class="prop-label">颜色</span>
                  <div class="prop-input">
                    <input id="model-mat-color" type="color" oninput="editor.updateModelMaterial('color', this.value)">
                  </div>
                </div>
                <div class="prop-row">
                  <span class="prop-label">粗糙度</span>
                  <input id="model-mat-roughness" type="range" min="0" max="1" step="0.01" oninput="editor.updateModelMaterial('roughness', this.value)">
                  <span class="prop-value" id="model-val-roughness">0.5</span>
                </div>
                <div class="prop-row">
                  <span class="prop-label">金属度</span>
                  <input id="model-mat-metalness" type="range" min="0" max="1" step="0.01" oninput="editor.updateModelMaterial('metalness', this.value)">
                  <span class="prop-value" id="model-val-metalness">0</span>
                </div>
              </div>
            </div>
            
            <!-- 子物体材质 -->
            <div id="props-child" style="display:none;">
              <div style="font-size:11px;color:#888;padding:8px 12px;border-bottom:1px solid #333;">子物体材质</div>
              <div class="prop-group-content">
                <div style="font-size:10px;color:#666;margin-bottom:8px;">所属模型: <span id="child-parent-name"></span></div>
                <div class="prop-row">
                  <span class="prop-label">颜色</span>
                  <div class="prop-input">
                    <input id="child-mat-color" type="color" oninput="editor.updateChildMaterial('color', this.value)">
                  </div>
                </div>
                <div class="prop-row">
                  <span class="prop-label">粗糙度</span>
                  <input id="child-mat-roughness" type="range" min="0" max="1" step="0.01" oninput="editor.updateChildMaterial('roughness', this.value)">
                  <span class="prop-value" id="child-val-roughness">0.5</span>
                </div>
                <div class="prop-row">
                  <span class="prop-label">金属度</span>
                  <input id="child-mat-metalness" type="range" min="0" max="1" step="0.01" oninput="editor.updateChildMaterial('metalness', this.value)">
                  <span class="prop-value" id="child-val-metalness">0</span>
                </div>
              </div>
            </div>
            
            <!-- 未选择材质提示 -->
            <div id="props-material-empty" style="padding:40px 20px;text-align:center;color:#666;font-size:12px;">
              选择对象以编辑材质
            </div>
          </div>
          
          <!-- 灯光TAB -->
          <div id="tab-light" class="tab-panel">
            <div id="light-params" style="display:none;">
              <div class="prop-group-content">
                <div class="prop-row">
                  <span class="prop-label">类型</span>
                  <div class="prop-input">
                    <select id="light-type" onchange="editor.updateLightType(this.value)" style="width:100%;padding:6px 10px;background:#3c3c3c;border:1px solid #444;border-radius:4px;color:#e0e0e0;font-size:12px;">
                      <option value="point">点光源</option>
                      <option value="spot">聚光灯</option>
                      <option value="directional">平行光</option>
                      <option value="ambient">环境光</option>
                      <option value="hemisphere">半球光</option>
                    </select>
                  </div>
                </div>
                <div class="prop-row">
                  <span class="prop-label">颜色</span>
                  <div class="prop-input">
                    <input id="light-color" type="color" oninput="editor.updateLight('color', this.value)">
                  </div>
                </div>
                <div class="prop-row">
                  <span class="prop-label">强度</span>
                  <input id="light-intensity" type="range" min="0" max="10" step="0.1" value="1" oninput="editor.updateLight('intensity', this.value)">
                  <span class="prop-value" id="val-light-intensity">1.0</span>
                </div>
                <div id="light-specific-params"></div>
                <div class="prop-row" style="margin-top:12px;padding-top:12px;border-top:1px solid #333;">
                  <label class="checkbox-row">
                    <input id="light-cast-shadow" type="checkbox" onchange="editor.updateLight('castShadow', this.checked)">
                    <span>投射阴影</span>
                  </label>
                </div>
                <div id="shadow-params" style="opacity:0.5;pointer-events:none;">
                  <div class="prop-row">
                    <span class="prop-label">阴影大小</span>
                    <div class="prop-input">
                      <select id="light-shadow-size" onchange="editor.updateLightShadow('mapSize', this.value)" style="width:100%;padding:6px 10px;background:#3c3c3c;border:1px solid #444;border-radius:4px;color:#e0e0e0;font-size:12px;">
                        <option value="512">512x512</option>
                        <option value="1024" selected>1024x1024</option>
                        <option value="2048">2048x2048</option>
                        <option value="4096">4096x4096</option>
                      </select>
                    </div>
                  </div>
                  <div class="prop-row">
                    <span class="prop-label">阴影偏差</span>
                    <input id="light-shadow-bias" type="range" min="-0.01" max="0.01" step="0.0001" value="-0.001" oninput="editor.updateLightShadow('bias', this.value)">
                    <span class="prop-value" id="val-shadow-bias">-0.001</span>
                  </div>
                </div>
              </div>
            </div>
            <div id="light-empty" style="padding:40px 20px;text-align:center;color:#666;font-size:12px;">
              选择灯光以编辑参数
            </div>
          </div>
          
          <!-- 物理TAB -->
          <div id="tab-physics" class="tab-panel">
            <div class="prop-group-content">
              <div class="prop-row">
                <span class="prop-label">重力 Y</span>
                <input id="gravity-y" type="range" min="-20" max="0" step="0.5" value="-9.8" oninput="editor.updateGravity()">
                <span class="prop-value" id="val-gravity">-9.8</span>
              </div>
              <div class="btn-row">
                <button onclick="editor.applyExplosion()">💥 爆炸</button>
                <button class="secondary" onclick="editor.applyUpForce()">⬆️ 推力</button>
              </div>
            </div>
          </div>
          
          <!-- 辉光TAB -->
          <div id="tab-bloom" class="tab-panel">
            <div class="prop-group-content">
              <div class="prop-row">
                <label class="checkbox-row">
                  <input id="pp-bloom" type="checkbox" checked onchange="editor.toggleBloom(this.checked)">
                  <span>启用 Bloom</span>
                </label>
              </div>
              <div class="prop-row">
                <span class="prop-label">强度</span>
                <input type="range" min="0" max="3" step="0.1" value="0.5" oninput="editor.setBloomStrength(this.value)">
                <span class="prop-value" id="val-bloom-strength">0.5</span>
              </div>
            </div>
          </div>
          
          <!-- 统计TAB -->
          <div id="tab-stats" class="tab-panel">
            <div class="prop-group-content">
              <div class="prop-row">
                <span class="prop-label">对象</span>
                <span id="stat-objects" style="color:#0e639c;font-weight:600;">0</span>
              </div>
              <div class="prop-row">
                <span class="prop-label">粒子</span>
                <span id="stat-particles" style="color:#0e639c;font-weight:600;">0</span>
              </div>
              <div class="prop-row">
                <span class="prop-label">刚体</span>
                <span id="stat-bodies" style="color:#0e639c;font-weight:600;">0</span>
              </div>
            </div>
          </div>
          
        </div>
      </div>
    </div>

    <!-- 状态栏 -->
    <div id="statusbar">
      <span>🟢 就绪</span>
      <span id="st-obj">0 对象</span>
      <span id="st-physics">⚙️ 物理运行</span>
      <span id="st-fps">-- FPS</span>
    </div>
  </div>

  <!-- 创建材质对话框 -->
  <div class="dialog-overlay" id="material-dialog">
    <div class="dialog">
      <div class="dialog-header">
        <span>🎨 新建材质</span>
        <button class="dialog-close" onclick="editor.hideMaterialDialog()">×</button>
      </div>
      <div class="dialog-body">
        <div class="prop-row">
          <span class="prop-label">名称</span>
          <div class="prop-input"><input id="mat-name" type="text" value="新材质" style="width:100%;"></div>
        </div>
        <div class="prop-row">
          <span class="prop-label">类型</span>
          <div class="prop-input">
            <select id="mat-type" style="width:100%;padding:6px 10px;background:#3c3c3c;border:1px solid #444;border-radius:4px;color:#e0e0e0;font-size:12px;">
              <option value="standard">标准材质 (Standard)</option>
              <option value="physical">物理材质 (Physical)</option>
              <option value="basic">基础材质 (Basic)</option>
              <option value="phong">高光材质 (Phong)</option>
              <option value="lambert">漫反射材质 (Lambert)</option>
            </select>
          </div>
        </div>
        <div class="prop-row">
          <span class="prop-label">颜色</span>
          <div class="prop-input">
            <input id="mat-base-color" type="color" value="#ffffff">
          </div>
        </div>
        <div class="btn-row">
          <button onclick="editor.createMaterial()">✅ 创建</button>
          <button class="secondary" onclick="editor.hideMaterialDialog()">取消</button>
        </div>
      </div>
    </div>
  </div>

  <!-- 贴图导入对话框 -->
  <div class="dialog-overlay" id="texture-dialog">
    <div class="dialog">
      <div class="dialog-header">
        <span>🖼️ 导入贴图</span>
        <button class="dialog-close" onclick="editor.hideTextureDialog()">×</button>
      </div>
      <div class="dialog-body">
        <div class="prop-row">
          <span class="prop-label">贴图类型</span>
          <div class="prop-input">
            <select id="tex-type" style="width:100%;padding:6px 10px;background:#3c3c3c;border:1px solid #444;border-radius:4px;color:#e0e0e0;font-size:12px;">
              <option value="map">颜色贴图 (Diffuse)</option>
              <option value="normalMap">法线贴图 (Normal)</option>
              <option value="roughnessMap">粗糙度贴图 (Roughness)</option>
              <option value="metalnessMap">金属度贴图 (Metalness)</option>
              <option value="aoMap">环境光遮蔽 (AO)</option>
              <option value="emissiveMap">自发光贴图 (Emissive)</option>
            </select>
          </div>
        </div>
        <div class="prop-row">
          <span class="prop-label">选择文件</span>
          <div class="prop-input">
            <input id="tex-file" type="file" accept="image/*" style="width:100%;color:#aaa;font-size:11px;">
          </div>
        </div>
        <div class="btn-row">
          <button onclick="editor.loadTexture()">📁 导入</button>
          <button class="secondary" onclick="editor.hideTextureDialog()">取消</button>
        </div>
      </div>
    </div>
  </div>

  <!-- 导出对话框 -->
  <div class="dialog-overlay" id="export-dialog">
    <div class="dialog">
      <div class="dialog-header">
        <span>📦 导出场景</span>
        <button class="dialog-close" onclick="editor.hideExportDialog()">×</button>
      </div>
      <div class="dialog-body">
        <div class="prop-row">
          <span class="prop-label">名称</span>
          <div class="prop-input"><input id="export-title" type="text" value="My Scene"></div>
        </div>
        <div class="btn-row">
          <button onclick="editor.performExport()">📥 下载 HTML</button>
        </div>
      </div>
    </div>
  </div>

  <!-- 加载画面 -->
  <div id="loading">
    <div class="spinner"></div>
    <div>正在初始化编辑器...</div>
  </div>

  <!-- 使用 ES Module 方式加载 Three.js -->
  <script type="importmap">
  {
    "imports": {
      "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
      "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/",
      "cannon-es": "https://cdn.jsdelivr.net/npm/cannon-es@0.20.0/dist/cannon-es.js"
    }
  }
  </script>
  
  <!-- 全局代理函数（在模块加载前可用） -->
  <script>
    // 全局 editor 变量（将由模块初始化）
    var editor = null;
    
    // Editor 方法代理 - 如果 editor 未加载则提示
    var editorProxy = function(method) {
      var args = Array.prototype.slice.call(arguments, 1);
      if (typeof editor === 'undefined' || !editor) {
        console.warn('编辑器尚未初始化');
        alert('编辑器正在加载中，请稍候...');
        return;
      }
      if (typeof editor[method] === 'function') {
        return editor[method].apply(editor, args);
      }
      console.warn('方法不存在:', method);
    };
    
    // 全局 switchTab 函数（供左侧面板使用）
    var switchTab = function(tab, el) {
      if (!editor) { alert('编辑器正在初始化，请稍候...'); return; }
      document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
      el.classList.add('active');
      ['scene', 'mateditor', 'lights', 'particles', 'presets'].forEach(function(t) {
        var panel = document.getElementById('panel-' + t);
        if (panel) panel.style.display = t === tab ? 'block' : 'none';
      });
      
      // 更新列表或调整大小
      if (tab === 'lights' && editor) {
        editor.updateLightList();
      } else if (tab === 'mateditor' && editor && editor.materialEditor) {
        // 切换到材质编辑器时更新库列表并调整大小
        editor.materialEditor.updateLibraryList();
        editor.materialEditor.syncFromSelection();
        setTimeout(function() { editor.materialEditor.resize(); }, 50);
      }
    };
    window.switchTab = switchTab;
    
    // 绑定常用方法到全局
    var methods = ['newScene', 'undo', 'redo', 'addCube', 'addSphere', 'addPhysicsBox', 'addEmissive', 
     'addLight', 'toggleSelectMode', 'toggleGrid', 'importModel', 'togglePhysics', 
     'showExportDialog', 'togglePanel', 'applyExplosion', 'applyUpForce', 'updateGravity',
     'toggleBloom', 'setBloomStrength', 'setTool', 'toggleSpace', 'deleteSelected',
     'focusOnObject', 'showCreateMaterialDialog',
     'matEditorAddNode', 'matEditorImportTexture', 'matEditorSelectSlot', 
     'matEditorLoadFromLibrary', 'matEditorApplyToSelected', 'selectMaterial',
     'assignMaterialToSelected', 'deleteMaterial', 'createMaterial', 'hideMaterialDialog',
     'importTextureForMesh', 'updateMeshMaterial', 'updateModelMaterial', 'updateChildMaterial',
     'updateTransform', 'updateLight', 'updateLightType', 'updateLightShadow', 'createLight'
    ];
    methods.forEach(function(method) {
      window[method] = function() {
        var args = Array.prototype.slice.call(arguments);
        args.unshift(method);
        return editorProxy.apply(null, args);
      };
    });
  </script>

  <script type="module">
    // 全局错误处理
    window.addEventListener('error', function(e) {
      console.error('全局错误:', e.error);
      alert('发生错误: ' + (e.error ? e.error.message : '未知错误'));
    });
    
    // 动态导入模块
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { TransformControls } from 'three/addons/controls/TransformControls.js';
    import { RectAreaLightUniformsLib } from 'three/addons/lights/RectAreaLightUniformsLib.js';
    import { RectAreaLightHelper } from 'three/addons/helpers/RectAreaLightHelper.js';
    import * as CANNON from 'cannon-es';

    console.log('✅ Three.js 加载成功:', THREE.REVISION);
    console.log('✅ Cannon.js 加载成功');
    
    // 初始化 RectAreaLight 统一库
    RectAreaLightUniformsLib.init();
    
    // 注意：editor 变量已在全局 script 中定义，这里直接使用

    // ============================================
    // 材质库管理器
    // ============================================
    class MaterialLibrary {
      constructor(scene) {
        this.scene = scene;
        this.materials = new Map();
        this.textures = new Map();
        this.materialCounter = 0;
        
        // 创建默认材质
        this.createDefaultMaterials();
      }
      
      createDefaultMaterials() {
        // 默认标准材质
        const defaultMat = new THREE.MeshStandardMaterial({ 
          color: 0xcccccc, 
          roughness: 0.5, 
          metalness: 0 
        });
        defaultMat.name = '默认材质';
        this.addMaterial('mat_default', defaultMat, 'standard');
        
        // 金属材质
        const metalMat = new THREE.MeshStandardMaterial({ 
          color: 0xaaaaaa, 
          roughness: 0.2, 
          metalness: 1.0 
        });
        metalMat.name = '金属材质';
        this.addMaterial('mat_metal', metalMat, 'standard');
        
        // 发光材质
        const emissiveMat = new THREE.MeshStandardMaterial({ 
          color: 0xff6600, 
          emissive: 0xff4400, 
          emissiveIntensity: 0.5,
          roughness: 0.5 
        });
        emissiveMat.name = '发光材质';
        this.addMaterial('mat_emissive', emissiveMat, 'standard');
        
        // 玻璃材质
        const glassMat = new THREE.MeshPhysicalMaterial({
          color: 0xffffff,
          metalness: 0,
          roughness: 0,
          transmission: 0.9,
          thickness: 0.5,
          transparent: true
        });
        glassMat.name = '玻璃材质';
        this.addMaterial('mat_glass', glassMat, 'physical');
      }
      
      addMaterial(id, material, type = 'standard') {
        this.materials.set(id, {
          id,
          material,
          type,
          name: material.name || `材质 ${++this.materialCounter}`,
          textures: new Map()
        });
        return id;
      }
      
      createMaterial(type, name, params = {}) {
        const id = 'mat_' + Date.now();
        let material;
        
        switch(type) {
          case 'standard':
            material = new THREE.MeshStandardMaterial({
              color: params.color || 0xffffff,
              roughness: params.roughness ?? 0.5,
              metalness: params.metalness ?? 0
            });
            break;
          case 'physical':
            material = new THREE.MeshPhysicalMaterial({
              color: params.color || 0xffffff,
              roughness: params.roughness ?? 0.5,
              metalness: params.metalness ?? 0,
              transmission: params.transmission ?? 0,
              thickness: params.thickness ?? 0
            });
            break;
          case 'basic':
            material = new THREE.MeshBasicMaterial({
              color: params.color || 0xffffff
            });
            break;
          case 'phong':
            material = new THREE.MeshPhongMaterial({
              color: params.color || 0xffffff,
              shininess: params.shininess ?? 30
            });
            break;
          case 'lambert':
            material = new THREE.MeshLambertMaterial({
              color: params.color || 0xffffff
            });
            break;
          default:
            material = new THREE.MeshStandardMaterial({ color: 0xffffff });
        }
        
        material.name = name || `新材质 ${++this.materialCounter}`;
        return this.addMaterial(id, material, type);
      }
      
      deleteMaterial(id) {
        const matData = this.materials.get(id);
        if (matData) {
          matData.material.dispose();
          this.materials.delete(id);
        }
      }
      
      assignMaterial(materialId, object) {
        const matData = this.materials.get(materialId);
        if (!matData || !object) return false;
        
        // 克隆材质给对象使用
        const clonedMat = matData.material.clone();
        clonedMat.name = matData.name;
        
        if (object.isMesh) {
          object.material = clonedMat;
          object.userData.materialRef = materialId;
          return true;
        } else if (object.isGroup || object.userData?.isImportedModel) {
          // 应用到组内所有网格
          let applied = false;
          object.traverse((child) => {
            if (child.isMesh) {
              child.material = clonedMat.clone();
              child.userData.materialRef = materialId;
              applied = true;
            }
          });
          return applied;
        }
        return false;
      }
      
      getMaterialList() {
        return Array.from(this.materials.values()).map(m => ({
          id: m.id,
          name: m.name,
          type: m.type,
          preview: this.generatePreview(m.material)
        }));
      }
      
      generatePreview(material) {
        // 返回材质颜色作为预览
        if (material.color) {
          return '#' + material.color.getHexString();
        }
        return '#888888';
      }
      
      async importTexture(file, type = 'map') {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const textureLoader = new THREE.TextureLoader();
            textureLoader.load(e.target.result, (texture) => {
              texture.name = file.name;
              const texId = 'tex_' + Date.now();
              this.textures.set(texId, { id: texId, texture, type, name: file.name });
              resolve({ id: texId, texture });
            }, undefined, reject);
          };
          reader.readAsDataURL(file);
        });
      }
      
      applyTexture(materialId, textureId, mapType = 'map') {
        const matData = this.materials.get(materialId);
        const texData = this.textures.get(textureId);
        if (!matData || !texData) return false;
        
        matData.material[mapType] = texData.texture;
        if (mapType === 'map' || mapType === 'emissiveMap' || mapType === 'aoMap') {
          texData.texture.colorSpace = THREE.SRGBColorSpace;
        }
        matData.material.needsUpdate = true;
        matData.textures.set(mapType, textureId);
        return true;
      }
      
      getTextureList() {
        return Array.from(this.textures.values()).map(t => ({
          id: t.id,
          name: t.name,
          type: t.type
        }));
      }
    }

    // ============================================
    // 材质节点编辑器
    // ============================================
    class NodeEditor {
      constructor(canvasId) {
        this.canvas = document.getElementById(canvasId);
        if (!this.canvas) {
          console.warn('NodeEditor: Canvas not found:', canvasId);
          return;
        }
        this.ctx = this.canvas.getContext('2d');
        this.nodes = [];
        this.links = [];
        this.selectedNode = null;
        this.draggedNode = null;
        this.isDragging = false;
        this.isConnecting = false;
        this.connectFrom = null;
        this.mouse = { x: 0, y: 0 };
        this.offset = { x: 0, y: 0 };
        this.scale = 1;
        
        this.setupEvents();
        this.resize();
      }
      
      resize() {
        if (!this.canvas) return;
        const parent = this.canvas.parentElement;
        if (!parent) return;
        const rect = parent.getBoundingClientRect();
        if (rect.width === 0 || rect.height === 0) return;
        this.canvas.width = rect.width;
        this.canvas.height = rect.height;
        this.render();
      }
      
      setupEvents() {
        this.canvas.addEventListener('mousedown', (e) => this.onMouseDown(e));
        this.canvas.addEventListener('mousemove', (e) => this.onMouseMove(e));
        this.canvas.addEventListener('mouseup', (e) => this.onMouseUp(e));
        this.canvas.addEventListener('wheel', (e) => this.onWheel(e));
        window.addEventListener('resize', () => this.resize());
      }
      
      getMousePos(e) {
        const rect = this.canvas.getBoundingClientRect();
        return {
          x: (e.clientX - rect.left - this.offset.x) / this.scale,
          y: (e.clientY - rect.top - this.offset.y) / this.scale
        };
      }
      
      onMouseDown(e) {
        const pos = this.getMousePos(e);
        this.mouse = pos;
        
        // 检查是否点击了节点
        const clickedNode = this.nodes.find(n => this.isPointInNode(pos, n));
        
        if (clickedNode) {
          this.selectedNode = clickedNode;
          this.draggedNode = clickedNode;
          this.isDragging = true;
        } else {
          this.selectedNode = null;
        }
        
        this.render();
      }
      
      onMouseMove(e) {
        const pos = this.getMousePos(e);
        
        if (this.isDragging && this.draggedNode) {
          this.draggedNode.x = pos.x - this.draggedNode.width / 2;
          this.draggedNode.y = pos.y - 20;
          this.render();
        }
        
        this.mouse = pos;
      }
      
      onMouseUp(e) {
        this.isDragging = false;
        this.draggedNode = null;
      }
      
      onWheel(e) {
        e.preventDefault();
        const delta = e.deltaY > 0 ? 0.9 : 1.1;
        this.scale *= delta;
        this.scale = Math.max(0.5, Math.min(2, this.scale));
        this.render();
      }
      
      isPointInNode(pos, node) {
        return pos.x >= node.x && pos.x <= node.x + node.width &&
               pos.y >= node.y && pos.y <= node.y + node.height;
      }
      
      addNode(type, x = 100, y = 100) {
        const node = {
          id: 'node_' + Date.now(),
          type,
          x,
          y,
          width: 120,
          height: type === 'output' ? 60 : 80,
          inputs: [],
          outputs: [],
          params: {}
        };
        
        // 配置节点接口
        switch(type) {
          case 'color':
            node.title = '颜色';
            node.outputs = [{ name: '颜色', type: 'color' }];
            node.params = { color: '#ffffff' };
            break;
          case 'texture':
            node.title = '纹理';
            node.inputs = [{ name: 'UV', type: 'vector' }];
            node.outputs = [{ name: '颜色', type: 'color' }, { name: 'Alpha', type: 'value' }];
            node.params = { texture: null };
            break;
          case 'mix':
            node.title = '混合';
            node.inputs = [
              { name: 'A', type: 'color' },
              { name: 'B', type: 'color' },
              { name: '系数', type: 'value' }
            ];
            node.outputs = [{ name: '结果', type: 'color' }];
            node.params = { blendMode: 'mix' };
            break;
          case 'value':
            node.title = '数值';
            node.outputs = [{ name: '值', type: 'value' }];
            node.params = { value: 0.5 };
            break;
          case 'output':
            node.title = '材质输出';
            node.inputs = [
              { name: '基础色', type: 'color' },
              { name: '粗糙度', type: 'value' },
              { name: '金属度', type: 'value' },
              { name: '法线', type: 'vector' }
            ];
            break;
        }
        
        this.nodes.push(node);
        this.render();
        return node;
      }
      
      deleteNode(nodeId) {
        this.nodes = this.nodes.filter(n => n.id !== nodeId);
        this.links = this.links.filter(l => l.from !== nodeId && l.to !== nodeId);
        this.render();
      }
      
      connectNodes(fromId, toId, fromSocket, toSocket) {
        this.links.push({ from: fromId, to: toId, fromSocket, toSocket });
        this.render();
      }
      
      clear() {
        this.nodes = [];
        this.links = [];
        this.render();
      }
      
      render() {
        const ctx = this.ctx;
        const w = this.canvas.width;
        const h = this.canvas.height;
        
        // 清空画布
        ctx.fillStyle = '#1a1a1a';
        ctx.fillRect(0, 0, w, h);
        
        // 绘制网格
        ctx.save();
        ctx.translate(this.offset.x, this.offset.y);
        ctx.scale(this.scale, this.scale);
        
        this.drawGrid(ctx);
        
        // 绘制连线
        this.links.forEach(link => {
          const fromNode = this.nodes.find(n => n.id === link.from);
          const toNode = this.nodes.find(n => n.id === link.to);
          if (fromNode && toNode) {
            this.drawConnection(ctx, fromNode, toNode, link);
          }
        });
        
        // 绘制节点
        this.nodes.forEach(node => {
          this.drawNode(ctx, node);
        });
        
        ctx.restore();
      }
      
      drawGrid(ctx) {
        ctx.strokeStyle = '#252525';
        ctx.lineWidth = 1;
        const gridSize = 20;
        
        for (let x = 0; x < 2000; x += gridSize) {
          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, 2000);
          ctx.stroke();
        }
        
        for (let y = 0; y < 2000; y += gridSize) {
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(2000, y);
          ctx.stroke();
        }
      }
      
      drawNode(ctx, node) {
        const isSelected = node === this.selectedNode;
        
        // 节点背景
        ctx.fillStyle = isSelected ? '#2a3a4a' : '#252526';
        ctx.strokeStyle = isSelected ? '#0e639c' : '#444';
        ctx.lineWidth = isSelected ? 2 : 1;
        
        ctx.beginPath();
        ctx.roundRect(node.x, node.y, node.width, node.height, 6);
        ctx.fill();
        ctx.stroke();
        
        // 标题栏
        ctx.fillStyle = '#333';
        ctx.beginPath();
        ctx.roundRect(node.x, node.y, node.width, 24, [6, 6, 0, 0]);
        ctx.fill();
        
        // 标题文字
        ctx.fillStyle = '#ddd';
        ctx.font = '11px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(node.title, node.x + node.width / 2, node.y + 16);
        
        // 输入接口
        node.inputs.forEach((input, i) => {
          const y = node.y + 40 + i * 20;
          ctx.fillStyle = '#666';
          ctx.beginPath();
          ctx.arc(node.x, y, 5, 0, Math.PI * 2);
          ctx.fill();
          
          ctx.fillStyle = '#aaa';
          ctx.textAlign = 'left';
          ctx.fillText(input.name, node.x + 10, y + 3);
        });
        
        // 输出接口
        node.outputs.forEach((output, i) => {
          const y = node.y + 40 + i * 20;
          ctx.fillStyle = '#0e639c';
          ctx.beginPath();
          ctx.arc(node.x + node.width, y, 5, 0, Math.PI * 2);
          ctx.fill();
          
          ctx.fillStyle = '#aaa';
          ctx.textAlign = 'right';
          ctx.fillText(output.name, node.x + node.width - 10, y + 3);
        });
      }
      
      drawConnection(ctx, fromNode, toNode, link) {
        const fromY = fromNode.y + 40 + (link.fromSocketIndex || 0) * 20;
        const toY = toNode.y + 40 + (link.toSocketIndex || 0) * 20;
        
        ctx.strokeStyle = '#0e639c';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(fromNode.x + fromNode.width, fromY);
        
        const cp1x = fromNode.x + fromNode.width + 50;
        const cp2x = toNode.x - 50;
        
        ctx.bezierCurveTo(cp1x, fromY, cp2x, toY, toNode.x, toY);
        ctx.stroke();
      }
      
      // 编译节点图为 Three.js 材质
      compile() {
        // 简化版本：直接返回第一个输出节点的输入颜色
        const outputNode = this.nodes.find(n => n.type === 'output');
        if (!outputNode) return null;
        
        // 这里应该遍历节点图并生成材质
        // 简化实现：创建一个基础材质
        return new THREE.MeshStandardMaterial({ color: 0xffffff });
      }
    }

    // ============================================
    // Slate 材质编辑器
    // ============================================
    class MaterialEditor {
      constructor(editor) {
        this.editor = editor;
        this.currentMaterial = null;
        this.materialType = 'standard';
        this.selectedSlot = null;
        this.textures = {};
        this.previewScene = null;
        this.previewCamera = null;
        this.previewRenderer = null;
        this.previewMesh = null;
        this.nodeEditor = null;
        
        this.init();
      }
      
      init() {
        this.initPreview();
        this.initNodeEditor();
        this.createDefaultMaterial();
      }
      
      initPreview() {
        const canvas = document.getElementById('mat-preview-canvas');
        if (!canvas) return;
        
        // 创建预览场景
        this.previewScene = new THREE.Scene();
        this.previewScene.background = new THREE.Color(0x2a2a2a);
        
        // 添加灯光
        const ambient = new THREE.AmbientLight(0xffffff, 0.4);
        this.previewScene.add(ambient);
        
        const dir = new THREE.DirectionalLight(0xffffff, 1);
        dir.position.set(5, 5, 5);
        this.previewScene.add(dir);
        
        const point = new THREE.PointLight(0xffffff, 0.5);
        point.position.set(-5, 3, -5);
        this.previewScene.add(point);
        
        // 相机
        this.previewCamera = new THREE.PerspectiveCamera(45, canvas.clientWidth / canvas.clientHeight, 0.1, 100);
        this.previewCamera.position.set(0, 0, 4);
        
        // 渲染器
        this.previewRenderer = new THREE.WebGLRenderer({ canvas, antialias: true });
        this.previewRenderer.setSize(canvas.clientWidth, canvas.clientHeight);
        this.previewRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        
        // 创建预览球体
        const geometry = new THREE.SphereGeometry(1, 64, 64);
        this.currentMaterial = new THREE.MeshStandardMaterial({ color: 0xffffff });
        this.previewMesh = new THREE.Mesh(geometry, this.currentMaterial);
        this.previewScene.add(this.previewMesh);
        
        // 开始渲染循环
        this.animatePreview();
      }
      
      animatePreview() {
        if (!this.previewMesh) return;
        
        requestAnimationFrame(() => this.animatePreview());
        
        // 缓慢旋转预览模型
        this.previewMesh.rotation.y += 0.005;
        this.previewMesh.rotation.x += 0.002;
        
        if (this.previewRenderer && this.previewCamera) {
          this.previewRenderer.render(this.previewScene, this.previewCamera);
        }
      }
      
      initNodeEditor() {
        const canvas = document.getElementById('mat-node-canvas');
        if (canvas) {
          this.nodeEditor = new NodeEditor('mat-node-canvas');
          // 添加输出节点
          this.nodeEditor.addNode('output', 300, 100);
        }
      }
      
      createDefaultMaterial() {
        this.currentMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,
          roughness: 0.5,
          metalness: 0
        });
        this.updateUIFromMaterial();
      }
      
      createMaterial(type) {
        this.materialType = type;
        
        let oldColor = this.currentMaterial?.color || new THREE.Color(0xffffff);
        let oldRoughness = this.currentMaterial?.roughness ?? 0.5;
        let oldMetalness = this.currentMaterial?.metalness ?? 0;
        
        switch(type) {
          case 'standard':
            this.currentMaterial = new THREE.MeshStandardMaterial({
              color: oldColor,
              roughness: oldRoughness,
              metalness: oldMetalness
            });
            break;
          case 'physical':
            this.currentMaterial = new THREE.MeshPhysicalMaterial({
              color: oldColor,
              roughness: oldRoughness,
              metalness: oldMetalness,
              clearcoat: 0,
              clearcoatRoughness: 0.1,
              transmission: 0,
              thickness: 0
            });
            break;
          case 'basic':
            this.currentMaterial = new THREE.MeshBasicMaterial({
              color: oldColor
            });
            break;
        }
        
        // 更新预览网格的材质
        if (this.previewMesh) {
          this.previewMesh.material = this.currentMaterial;
        }
        
        this.updateUIFromMaterial();
        return this.currentMaterial;
      }
      
      updateUIFromMaterial() {
        if (!this.currentMaterial) return;
        
        const mat = this.currentMaterial;
        
        // 更新颜色
        const colorInput = document.getElementById('me-color');
        const colorHex = document.getElementById('me-color-hex');
        if (colorInput) colorInput.value = '#' + mat.color.getHexString();
        if (colorHex) colorHex.value = '#' + mat.color.getHexString();
        
        // 更新自发光
        const emissiveInput = document.getElementById('me-emissive');
        const emissiveIntInput = document.getElementById('me-emissive-intensity');
        if (emissiveInput && mat.emissive) {
          emissiveInput.value = '#' + mat.emissive.getHexString();
        }
        if (emissiveIntInput) {
          emissiveIntInput.value = mat.emissiveIntensity ?? 1;
        }
        
        // 更新粗糙度
        const roughnessInput = document.getElementById('me-roughness');
        const roughnessVal = document.getElementById('me-val-roughness');
        if (roughnessInput) roughnessInput.value = mat.roughness ?? 0.5;
        if (roughnessVal) roughnessVal.textContent = (mat.roughness ?? 0.5).toFixed(1);
        
        // 更新金属度
        const metalnessInput = document.getElementById('me-metalness');
        const metalnessVal = document.getElementById('me-val-metalness');
        if (metalnessInput) metalnessInput.value = mat.metalness ?? 0;
        if (metalnessVal) metalnessVal.textContent = (mat.metalness ?? 0).toFixed(1);
        
        // 更新透明度
        const opacityInput = document.getElementById('me-opacity');
        const opacityVal = document.getElementById('me-val-opacity');
        if (opacityInput) opacityInput.value = mat.opacity ?? 1;
        if (opacityVal) opacityVal.textContent = (mat.opacity ?? 1).toFixed(1);
        
        // 更新线框
        const wireframeInput = document.getElementById('me-wireframe');
        if (wireframeInput) wireframeInput.checked = mat.wireframe || false;
        
        // 更新双面
        const sideInput = document.getElementById('me-side');
        if (sideInput) sideInput.checked = mat.side === THREE.DoubleSide;
      }
      
      updateProperty(prop, value) {
        if (!this.currentMaterial) return;
        
        const mat = this.currentMaterial;
        
        switch(prop) {
          case 'color':
            mat.color.set(value);
            document.getElementById('me-color-hex').value = value;
            break;
          case 'emissive':
            if (mat.emissive) mat.emissive.set(value);
            break;
          case 'emissiveIntensity':
            if (mat.emissiveIntensity !== undefined) {
              mat.emissiveIntensity = parseFloat(value);
            }
            break;
          case 'roughness':
            mat.roughness = parseFloat(value);
            document.getElementById('me-val-roughness').textContent = parseFloat(value).toFixed(1);
            break;
          case 'metalness':
            mat.metalness = parseFloat(value);
            document.getElementById('me-val-metalness').textContent = parseFloat(value).toFixed(1);
            break;
          case 'opacity':
            mat.opacity = parseFloat(value);
            mat.transparent = parseFloat(value) < 1;
            document.getElementById('me-val-opacity').textContent = parseFloat(value).toFixed(1);
            break;
          case 'wireframe':
            mat.wireframe = value;
            break;
          case 'side':
            mat.side = value === 'double' ? THREE.DoubleSide : THREE.FrontSide;
            break;
        }
        
        mat.needsUpdate = true;
      }
      
      selectType(type) {
        this.materialType = type;
        
        // 更新UI选中状态
        document.querySelectorAll('#mat-editor-types .mat-type-item').forEach(item => {
          item.classList.toggle('selected', item.dataset.type === type);
        });
        
        this.createMaterial(type);
      }
      
      selectSlot(slot) {
        this.selectedSlot = slot;
        
        // 更新UI选中状态
        document.querySelectorAll('#me-texture-slots .me-slot').forEach(item => {
          item.classList.toggle('selected', item.dataset.slot === slot);
        });
      }
      
      async importTexture(slot) {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        
        input.onchange = async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          
          try {
            const reader = new FileReader();
            reader.onload = async (event) => {
              const textureLoader = new THREE.TextureLoader();
              const texture = await textureLoader.loadAsync(event.target.result);
              texture.colorSpace = THREE.SRGBColorSpace;
              
              // 应用到当前材质
              if (this.currentMaterial) {
                this.currentMaterial[slot] = texture;
                this.currentMaterial.needsUpdate = true;
                
                // 保存引用
                this.textures[slot] = texture;
                
                // 更新UI
                const slotEl = document.querySelector(`#me-texture-slots .me-slot[data-slot="${slot}"]`);
                if (slotEl) {
                  slotEl.classList.add('has-texture');
                  slotEl.querySelector('.status').textContent = '✓';
                }
                
                alert(`贴图 "${file.name}" 已导入`);
              }
            };
            reader.readAsDataURL(file);
          } catch (err) {
            alert('贴图导入失败: ' + err.message);
          }
        };
        
        input.click();
      }
      
      addNode(type) {
        if (this.nodeEditor) {
          const x = 50 + Math.random() * 150;
          const y = 50 + Math.random() * 100;
          this.nodeEditor.addNode(type, x, y);
        }
      }
      
      applyToSelected() {
        if (!this.currentMaterial || !this.editor.selected) {
          alert('请先创建材质并选择目标对象');
          return;
        }
        
        // 克隆材质应用到选中对象
        const clonedMat = this.currentMaterial.clone();
        
        if (this.editor.selected.isMesh) {
          this.editor.selected.material = clonedMat;
        } else if (this.editor.selected.userData?.isImportedModel) {
          // 应用到导入模型的所有子网格
          this.editor.selected.traverse(child => {
            if (child.isMesh) {
              child.material = clonedMat.clone();
            }
          });
        }
        
        this.editor.updateInputs();
        alert('材质已应用');
      }
      
      // 更新材质库列表显示
      updateLibraryList() {
        const container = document.getElementById('mat-editor-library');
        if (!container || !this.editor.materialLibrary) return;
        
        const materials = this.editor.materialLibrary.getMaterialList();
        if (materials.length === 0) {
          container.innerHTML = '<div style="font-size:11px;color:#666;padding:8px 0;">暂无材质</div>';
          return;
        }
        
        let html = '';
        materials.forEach(mat => {
          html += `
            <div class="material-item" onclick="editor.matEditorLoadFromLibrary('${mat.id}')" style="margin-bottom:6px;padding:8px;">
              <div class="material-preview" style="background:${mat.preview};width:24px;height:24px;"></div>
              <div class="material-info" style="flex:1;min-width:0;">
                <div class="material-name" style="font-size:11px;overflow:hidden;text-overflow:ellipsis;">${mat.name}</div>
                <div class="material-type" style="font-size:9px;">${mat.type}</div>
              </div>
            </div>
          `;
        });
        container.innerHTML = html;
      }
      
      // 从材质库加载材质
      loadFromLibrary(materialId) {
        const matData = this.editor.materialLibrary.materials.get(materialId);
        if (!matData) return;
        
        // 克隆材质到编辑器
        this.currentMaterial = matData.material.clone();
        this.materialType = matData.type;
        
        // 更新预览
        if (this.previewMesh) {
          this.previewMesh.material = this.currentMaterial;
        }
        
        this.updateUIFromMaterial();
        this.updateTextureSlots();
      }
      
      // 从当前选中对象同步材质
      syncFromSelection() {
        const targetEl = document.getElementById('mat-editor-target');
        const typeEl = document.getElementById('mat-editor-target-type');
        
        if (!this.editor.selected) {
          if (targetEl) targetEl.textContent = '未选择对象';
          if (typeEl) typeEl.textContent = '';
          return;
        }
        
        const obj = this.editor.selected;
        let targetMaterial = null;
        let targetName = obj.name || '未命名';
        let targetType = '';
        
        if (obj.isMesh) {
          // 网格对象（包括子物体）
          targetMaterial = obj.material;
          targetType = '🎲 网格';
          
          // 检查是否是子物体
          const parentModel = this.editor.getSelectedParentModel();
          if (parentModel) {
            targetType = `🔹 子物体 (来自: ${parentModel.name})`;
          }
        } else if (obj.userData?.isImportedModel) {
          // 导入的模型 - 使用第一个材质
          const materials = obj.userData.materials || [];
          const matIndex = this.editor.selectedMaterialIndex ?? 0;
          targetMaterial = materials[matIndex] || materials[0];
          targetType = '📦 导入模型';
        }
        
        // 更新UI显示
        if (targetEl) targetEl.textContent = targetName;
        if (typeEl) typeEl.textContent = targetType;
        
        // 如果有材质，同步到编辑器
        if (targetMaterial) {
          this.currentMaterial = targetMaterial.clone();
          if (this.previewMesh) {
            this.previewMesh.material = this.currentMaterial;
          }
          this.updateUIFromMaterial();
          this.updateTextureSlots();
        }
      }
      
      // 更新贴图槽显示状态
      updateTextureSlots() {
        if (!this.currentMaterial) return;
        
        const slots = ['map', 'normalMap', 'roughnessMap', 'metalnessMap'];
        slots.forEach(slot => {
          const slotEl = document.querySelector(`#me-texture-slots .me-slot[data-slot="${slot}"]`);
          if (slotEl) {
            const hasTexture = this.currentMaterial[slot] !== null && this.currentMaterial[slot] !== undefined;
            slotEl.classList.toggle('has-texture', hasTexture);
            slotEl.querySelector('.status').textContent = hasTexture ? '✓' : '空';
          }
        });
      }
      
      resize() {
        const canvas = document.getElementById('mat-preview-canvas');
        if (canvas && this.previewRenderer && this.previewCamera) {
          this.previewRenderer.setSize(canvas.clientWidth, canvas.clientHeight);
          this.previewCamera.aspect = canvas.clientWidth / canvas.clientHeight;
          this.previewCamera.updateProjectionMatrix();
        }
        
        if (this.nodeEditor) {
          this.nodeEditor.resize();
        }
      }
    }

    // ============================================
    // 编辑器主类
    // ============================================
    class Editor {
      constructor() {
        this.scene = null;
        this.camera = null;
        this.renderer = null;
        this.controls = null;
        this.transformCtrl = null;
        this.physics = null;
        this.raycaster = new THREE.Raycaster();
        this.mouse = new THREE.Vector2();
        
        this.objects = [];
        this.particleSystems = [];
        this.selected = null;
        this.history = [];
        this.historyIndex = -1;
        this.isPhysicsPaused = false;
        this.beforeTransform = null;
        
        // 新功能：材质库和节点编辑器
        this.materialLibrary = null;
        this.nodeEditor = null;
        this.materialEditor = null;
        this.selectedMaterial = null;
        this.lights = [];
        this.selectedLight = null;
        this.expandedNodes = new Set();
        
        // 选择模式：false=选择整个模型, true=选择子物体
        this.selectChildMode = false;
        
        this.init();
      }

      init() {
        try {
          console.log('🚀 开始初始化编辑器...');
          const canvas = document.getElementById('canvas');
          if (!canvas) {
            throw new Error('Canvas 元素未找到');
          }
          console.log('✅ Canvas 元素已找到');
          
          // 1. 渲染器
          console.log('🎨 创建渲染器...');
          this.renderer = new THREE.WebGLRenderer({ 
            canvas: canvas, 
            antialias: true,
            powerPreference: 'high-performance'
          });
          console.log('✅ 渲染器已创建');
          
          // 确保 canvas 有正确的父元素尺寸
          const parent = canvas.parentElement;
          console.log('📐 Canvas父元素尺寸:', parent.clientWidth, 'x', parent.clientHeight);
          const width = parent.clientWidth || 800;
          const height = parent.clientHeight || 600;
          console.log('📐 设置渲染器尺寸:', width, 'x', height);
          this.renderer.setSize(width, height);
          this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
          this.renderer.shadowMap.enabled = true;
          this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
          this.renderer.setClearColor(0x0a0a0a);
          this.renderer.toneMapping = THREE.ACESFilmicToneMapping;
          this.renderer.toneMappingExposure = 1.0;

          // 2. 场景
          this.scene = new THREE.Scene();
          this.scene.background = new THREE.Color(0x0a0a0a);
          this.scene.name = 'My Scene';
          console.log('✅ 场景已创建');

          // 3. 相机
          const aspect = width / height;
          this.camera = new THREE.PerspectiveCamera(60, aspect, 0.1, 1000);
          this.camera.position.set(5, 5, 5);
          this.camera.lookAt(0, 0, 0);
          console.log('✅ 相机已创建');

          // 4. 控制器
          this.controls = new OrbitControls(this.camera, canvas);
          this.controls.enableDamping = true;
          console.log('✅ 控制器已创建');

          // 5. 变换控制
          this.transformCtrl = new TransformControls(this.camera, canvas);
          this.transformCtrl.addEventListener('dragging-changed', (e) => {
            this.controls.enabled = !e.value;
          });
          this.transformCtrl.addEventListener('mouseDown', () => {
            if (this.selected) {
              this.beforeTransform = {
                position: this.selected.position.clone(),
                rotation: this.selected.rotation.clone(),
                scale: this.selected.scale.clone()
              };
            }
          });
          this.transformCtrl.addEventListener('mouseUp', () => {
            if (this.selected && this.beforeTransform) {
              this.executeCommand(new TransformCmd(this.selected, this.beforeTransform));
              this.beforeTransform = null;
            }
          });
          this.transformCtrl.addEventListener('change', () => this.updateInputs());
          this.scene.add(this.transformCtrl);

          // 6. 物理引擎
          this.initPhysics();
          
          // 7. 初始化材质库
          this.materialLibrary = new MaterialLibrary(this.scene);
          this.updateMaterialList();
          
          // 8. 初始化节点编辑器
          setTimeout(() => {
            this.nodeEditor = new NodeEditor('node-canvas');
          }, 100);
          
          // 9. 初始化 Slate 材质编辑器
          setTimeout(() => {
            this.materialEditor = new MaterialEditor(this);
          }, 200);

          // 10. 灯光
          console.log('💡 添加灯光...');
          const ambient = new THREE.AmbientLight(0x404040, 0.5);
          ambient.name = '环境光';
          this.scene.add(ambient);

          const dir = new THREE.DirectionalLight(0xffffff, 1);
          dir.name = '主光源';
          dir.position.set(5, 10, 5);
          dir.castShadow = true;
          this.scene.add(dir);
          console.log('✅ 灯光已添加');

          // 11. 网格和地面
          console.log('🌐 添加网格和地面...');
          this.gridHelper = new THREE.GridHelper(20, 20, 0x888888, 0x444444);
          this.gridHelper.name = '网格';
          this.scene.add(this.gridHelper);

          const ground = new THREE.Mesh(
            new THREE.PlaneGeometry(20, 20),
            new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 })
          );
          ground.rotation.x = -Math.PI / 2;
          ground.position.y = -0.01;
          ground.receiveShadow = true;
          this.scene.add(ground);
          console.log('✅ 网格和地面已添加');

          // 9. 事件
          window.addEventListener('resize', () => this.onResize());
          canvas.addEventListener('pointerdown', (e) => this.onPointerDown(e));
          window.addEventListener('keydown', (e) => this.onKeyDown(e));

          // 10. 启动动画
          this.animate();
          console.log('✅ 动画循环已启动');
          
          // 11. 初始化面板拖拽
          this.initResizers();
          
          // 12. 初始化右侧面板TAB
          this.initRightTabs();
          
          // 13. 延迟触发一次 resize 确保尺寸正确
          setTimeout(() => this.onResize(), 100);
          
          // 14. 隐藏加载
          document.getElementById('loading').classList.add('hidden');
          
          console.log('✅ 编辑器初始化完成');
          
          // 初始为空场景，不添加任何对象

        } catch (err) {
          console.error('❌ 初始化失败:', err);
          console.error('错误堆栈:', err.stack);
          const loadingDiv = document.querySelector('#loading div:last-child');
          if (loadingDiv) {
            loadingDiv.textContent = '初始化失败: ' + err.message;
          }
          alert('编辑器初始化失败: ' + err.message);
        }
      }

      initResizers() {
        const leftPanel = document.getElementById('left');
        const rightPanel = document.getElementById('right');
        const resizerLeft = document.getElementById('resizer-left');
        const resizerRight = document.getElementById('resizer-right');
        
        // 如果元素不存在则跳过
        if (!leftPanel || !rightPanel || !resizerLeft || !resizerRight) {
          console.warn('Resizer elements not found');
          return;
        }
        
        let isResizing = false;
        let currentResizer = null;
        let startX = 0;
        let startWidth = 0;
        
        const minWidth = 180;
        const maxWidth = 500;
        
        // 左侧面板拖拽
        resizerLeft.addEventListener('mousedown', (e) => {
          isResizing = true;
          currentResizer = 'left';
          startX = e.clientX;
          startWidth = leftPanel.offsetWidth;
          resizerLeft.classList.add('active');
          
          // 添加全局遮罩层
          const overlay = document.createElement('div');
          overlay.className = 'resizing-overlay';
          overlay.id = 'resizing-overlay';
          document.body.appendChild(overlay);
          
          e.preventDefault();
        });
        
        // 右侧面板拖拽
        resizerRight.addEventListener('mousedown', (e) => {
          isResizing = true;
          currentResizer = 'right';
          startX = e.clientX;
          startWidth = rightPanel.offsetWidth;
          resizerRight.classList.add('active');
          
          // 添加全局遮罩层
          const overlay = document.createElement('div');
          overlay.className = 'resizing-overlay';
          overlay.id = 'resizing-overlay';
          document.body.appendChild(overlay);
          
          e.preventDefault();
        });
        
        // 全局鼠标移动
        document.addEventListener('mousemove', (e) => {
          if (!isResizing) return;
          
          if (currentResizer === 'left') {
            const diff = e.clientX - startX;
            const newWidth = Math.max(minWidth, Math.min(maxWidth, startWidth + diff));
            leftPanel.style.width = newWidth + 'px';
          } else if (currentResizer === 'right') {
            const diff = startX - e.clientX;
            const newWidth = Math.max(minWidth, Math.min(maxWidth, startWidth + diff));
            rightPanel.style.width = newWidth + 'px';
          }
          
          // 触发窗口resize事件以更新canvas
          window.dispatchEvent(new Event('resize'));
        });
        
        // 全局鼠标释放
        document.addEventListener('mouseup', () => {
          if (isResizing) {
            isResizing = false;
            currentResizer = null;
            resizerLeft.classList.remove('active');
            resizerRight.classList.remove('active');
            
            // 移除遮罩层
            const overlay = document.getElementById('resizing-overlay');
            if (overlay) {
              overlay.remove();
            }
          }
        });
      }

      // 初始化右侧面板TAB
      initRightTabs() {
        const tabsContainer = document.getElementById('right-tabs');
        if (!tabsContainer) return;
        
        const tabs = tabsContainer.querySelectorAll('.right-tab');
        let draggedTab = null;
        
        // TAB点击切换
        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const tabName = tab.dataset.tab;
            this.switchRightTab(tabName);
          });
          
          // 拖拽开始
          tab.addEventListener('dragstart', (e) => {
            draggedTab = tab;
            tab.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
          });
          
          // 拖拽结束
          tab.addEventListener('dragend', () => {
            tab.classList.remove('dragging');
            tabs.forEach(t => t.classList.remove('drag-over'));
            draggedTab = null;
          });
          
          // 拖拽经过
          tab.addEventListener('dragover', (e) => {
            e.preventDefault();
            if (tab !== draggedTab) {
              tab.classList.add('drag-over');
            }
          });
          
          // 拖拽离开
          tab.addEventListener('dragleave', () => {
            tab.classList.remove('drag-over');
          });
          
          // 放置
          tab.addEventListener('drop', (e) => {
            e.preventDefault();
            tab.classList.remove('drag-over');
            
            if (draggedTab && draggedTab !== tab) {
              // 交换TAB位置
              const allTabs = Array.from(tabsContainer.querySelectorAll('.right-tab'));
              const draggedIndex = allTabs.indexOf(draggedTab);
              const targetIndex = allTabs.indexOf(tab);
              
              if (draggedIndex < targetIndex) {
                tab.after(draggedTab);
              } else {
                tab.before(draggedTab);
              }
            }
          });
        });
      }
      
      // 切换右侧面板TAB
      switchRightTab(tabName) {
        const tabs = document.querySelectorAll('.right-tab');
        const panels = document.querySelectorAll('.tab-panel');
        
        tabs.forEach(tab => {
          tab.classList.toggle('active', tab.dataset.tab === tabName);
        });
        
        panels.forEach(panel => {
          panel.classList.toggle('active', panel.id === 'tab-' + tabName);
        });
      }

      initPhysics() {
        this.physics = {
          world: new CANNON.World({ gravity: new CANNON.Vec3(0, -9.82, 0) }),
          bodies: [],
          paused: false,
          
          addBox: (mesh, mass = 1) => {
            const shape = new CANNON.Box(new CANNON.Vec3(0.5, 0.5, 0.5));
            const body = new CANNON.Body({
              mass: mass,
              shape: shape,
              position: new CANNON.Vec3(mesh.position.x, mesh.position.y, mesh.position.z)
            });
            this.physics.world.addBody(body);
            this.physics.bodies.push({ mesh, body });
          },
          
          addGround: () => {
            const shape = new CANNON.Plane();
            const body = new CANNON.Body({ mass: 0, shape });
            body.quaternion.setFromEuler(-Math.PI / 2, 0, 0);
            this.physics.world.addBody(body);
          },
          
          update: (dt) => {
            if (this.physics.paused) return;
            this.physics.world.step(1/60, dt, 3);
            this.physics.bodies.forEach(({ mesh, body }) => {
              mesh.position.copy(body.position);
              mesh.quaternion.copy(body.quaternion);
            });
          },
          
          applyExplosion: (center, force, radius) => {
            this.physics.bodies.forEach(({ body }) => {
              if (body.mass === 0) return;
              const dist = body.position.distanceTo(new CANNON.Vec3(center.x, center.y, center.z));
              if (dist < radius) {
                const dir = body.position.vsub(new CANNON.Vec3(center.x, center.y, center.z));
                dir.normalize();
                const f = force * (1 - dist / radius);
                body.applyImpulse(dir.scale(f), body.position);
              }
            });
          },
          
          applyUpForce: (force) => {
            this.physics.bodies.forEach(({ body }) => {
              if (body.mass > 0) {
                body.applyImpulse(new CANNON.Vec3(0, force, 0), body.position);
              }
            });
          },
          
          clear: () => {
            this.physics.bodies.forEach(({ body }) => {
              this.physics.world.removeBody(body);
            });
            this.physics.bodies = [];
            this.physics.addGround();
          }
        };
        this.physics.addGround();
      }

      animate() {
        requestAnimationFrame(() => this.animate());
        
        try {
          if (this.physics) this.physics.update(0.016);
          this.updateParticles();
          this.controls.update();
          if (this.renderer && this.scene && this.camera) {
            this.renderer.render(this.scene, this.camera);
          }
          this.updateStats();
          // FPS 计数
          if (typeof frames !== 'undefined') frames++;
        } catch (err) {
          console.error('❌ 渲染循环错误:', err);
        }
      }

      onResize() {
        const canvas = document.getElementById('canvas');
        const parent = canvas.parentElement;
        this.camera.aspect = parent.clientWidth / parent.clientHeight;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(parent.clientWidth, parent.clientHeight);
      }

      onPointerDown(e) {
        if (e.button !== 0) return;
        
        const canvas = document.getElementById('canvas');
        const rect = canvas.getBoundingClientRect();
        this.mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
        this.mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

        this.raycaster.setFromCamera(this.mouse, this.camera);
        
        // 1. 优先检测灯光的点击区域（扩大检测范围）
        const lightHitBoxes = [];
        this.lights.forEach(light => {
          light.traverse(child => {
            if (child.userData.isLightHitBox) {
              lightHitBoxes.push(child);
            }
          });
        });
        
        const lightIntersects = this.raycaster.intersectObjects(lightHitBoxes);
        if (lightIntersects.length > 0 && !this.transformCtrl.dragging) {
          const hitBox = lightIntersects[0].object;
          const parentLight = hitBox.userData.parentLight;
          if (parentLight) {
            this.select(parentLight);
            return;
          }
        }
        
        // 2. 检测普通网格（包括导入模型的子网格）
        // 收集所有可选择的网格
        const selectableMeshes = [];
        
        this.objects.forEach(obj => {
          if (obj.isMesh && !obj.userData.isLightHelper) {
            selectableMeshes.push(obj);
          }
          // 如果是导入的模型，递归收集子网格
          if (obj.userData?.isImportedModel || obj.type === 'Group') {
            obj.traverse(child => {
              if (child.isMesh && !child.userData.isLightHelper) {
                child.userData.parentGroup = obj; // 记录父级引用
                selectableMeshes.push(child);
              }
            });
          }
        });
        
        const intersects = this.raycaster.intersectObjects(selectableMeshes, false);

        if (intersects.length > 0 && !this.transformCtrl.dragging) {
          const hitObject = intersects[0].object;
          
          // 如果点击的是导入模型的子网格
          if (hitObject.userData.parentGroup && !this.selectChildMode) {
            // 默认选中整个模型
            this.select(hitObject.userData.parentGroup);
          } else {
            // 直接选中点击的对象（子网格或普通物体）
            this.select(hitObject);
          }
        } else if (!this.transformCtrl.dragging) {
          this.select(null);
        }
      }

      onKeyDown(e) {
        if (e.target.tagName === 'INPUT') return;
        
        switch(e.key.toLowerCase()) {
          case 't': this.setTool('translate'); break;
          case 'r': this.setTool('rotate'); break;
          case 's': this.setTool('scale'); break;
          case 'delete':
          case 'backspace': this.deleteSelected(); break;
          case 'z': 
            if (e.ctrlKey || e.metaKey) {
              e.shiftKey ? this.redo() : this.undo();
            }
            break;
        }
      }

      // 添加对象
      addCube() {
        const geo = new THREE.BoxGeometry(1, 1, 1);
        const mat = new THREE.MeshStandardMaterial({ color: new THREE.Color().setHSL(Math.random(), 0.7, 0.5) });
        const mesh = new THREE.Mesh(geo, mat);
        mesh.name = '立方体 ' + (this.objects.filter(o => o.name?.includes('立方')).length + 1);
        mesh.position.set((Math.random()-0.5)*4, 1, (Math.random()-0.5)*4);
        mesh.castShadow = true;
        mesh.receiveShadow = true;
        
        this.scene.add(mesh);
        this.objects.push(mesh);
        this.executeCommand(new AddObjectCmd(this, mesh));
        this.select(mesh);
      }

      addSphere() {
        const geo = new THREE.SphereGeometry(0.5, 32, 16);
        const mat = new THREE.MeshStandardMaterial({ color: new THREE.Color().setHSL(Math.random(), 0.7, 0.5) });
        const mesh = new THREE.Mesh(geo, mat);
        mesh.name = '球体 ' + (this.objects.filter(o => o.name?.includes('球')).length + 1);
        mesh.position.set((Math.random()-0.5)*4, 1, (Math.random()-0.5)*4);
        mesh.castShadow = true;
        mesh.receiveShadow = true;
        
        this.scene.add(mesh);
        this.objects.push(mesh);
        this.executeCommand(new AddObjectCmd(this, mesh));
        this.select(mesh);
      }

      addPhysicsBox() {
        const geo = new THREE.BoxGeometry(1, 1, 1);
        const mat = new THREE.MeshStandardMaterial({ color: new THREE.Color().setHSL(Math.random(), 0.7, 0.5) });
        const mesh = new THREE.Mesh(geo, mat);
        mesh.name = '物理盒子 ' + (this.objects.filter(o => o.name?.includes('物理')).length + 1);
        mesh.position.set((Math.random()-0.5)*4, 5 + Math.random() * 3, (Math.random()-0.5)*4);
        mesh.rotation.set(Math.random(), Math.random(), Math.random());
        mesh.castShadow = true;
        mesh.receiveShadow = true;
        
        this.scene.add(mesh);
        this.objects.push(mesh);
        
        if (this.physics) {
          this.physics.addBox(mesh, 1);
        }
        
        this.executeCommand(new AddObjectCmd(this, mesh));
        this.select(mesh);
      }

      addEmissive() {
        const geo = new THREE.BoxGeometry(0.8, 0.8, 0.8);
        const mat = new THREE.MeshStandardMaterial({ 
          color: new THREE.Color().setHSL(Math.random() * 0.1 + 0.5, 0.8, 0.5),
          emissive: new THREE.Color().setHSL(Math.random() * 0.1 + 0.05, 1, 0.5),
          emissiveIntensity: 2
        });
        const mesh = new THREE.Mesh(geo, mat);
        mesh.name = '发光体 ' + (this.objects.filter(o => o.name?.includes('发光')).length + 1);
        mesh.position.set((Math.random()-0.5)*3, 1, (Math.random()-0.5)*3);
        mesh.castShadow = true;
        
        this.scene.add(mesh);
        this.objects.push(mesh);
        this.executeCommand(new AddObjectCmd(this, mesh));
        this.select(mesh);
      }

      // ============================================
      // 灯光系统方法
      // ============================================
      
      addLightByType() {
        const type = document.getElementById('light-type-select').value;
        this.createLight(type);
      }
      
      createLight(type, params = {}) {
        let light;
        const color = params.color || new THREE.Color(0xffffff);
        const intensity = params.intensity ?? 1;
        const name = params.name || this.getLightDefaultName(type);
        
        switch(type) {
          case 'point':
            light = new THREE.PointLight(color, intensity, params.distance || 10, params.decay || 2);
            light.userData.lightType = 'point';
            break;
          case 'spot':
            light = new THREE.SpotLight(color, intensity);
            light.angle = params.angle || Math.PI / 6;
            light.penumbra = params.penumbra || 0.5;
            light.distance = params.distance || 20;
            light.decay = params.decay || 2;
            light.userData.lightType = 'spot';
            break;
          case 'directional':
            light = new THREE.DirectionalLight(color, intensity);
            light.userData.lightType = 'directional';
            break;
          case 'ambient':
            light = new THREE.AmbientLight(color, intensity);
            light.userData.lightType = 'ambient';
            break;
          case 'hemisphere':
            light = new THREE.HemisphereLight(color, params.groundColor || 0x444444, intensity);
            light.userData.lightType = 'hemisphere';
            break;
          case 'rect':
            light = new THREE.RectAreaLight(color, intensity, params.width || 10, params.height || 10);
            light.userData.lightType = 'rect';
            break;
          default:
            light = new THREE.PointLight(color, intensity);
            light.userData.lightType = 'point';
        }
        
        light.name = name;
        light.position.set(
          params.x ?? (Math.random()-0.5)*5,
          params.y ?? (3 + Math.random() * 2),
          params.z ?? (Math.random()-0.5)*5
        );
        
        // 只有部分灯光类型支持阴影
        const canCastShadow = ['spot', 'directional', 'point'].includes(type);
        if (canCastShadow) {
          light.castShadow = params.castShadow ?? true;
          if (light.castShadow) {
            light.shadow.mapSize.width = params.shadowSize || 1024;
            light.shadow.mapSize.height = params.shadowSize || 1024;
            light.shadow.bias = params.shadowBias || -0.001;
          }
        }
        
        // 添加可视化辅助体
        if (type !== 'ambient' && type !== 'hemisphere') {
          // 主要可视化球体
          const helperGeo = new THREE.SphereGeometry(0.2, 16, 16);
          const helperMat = new THREE.MeshBasicMaterial({ color: color });
          const helper = new THREE.Mesh(helperGeo, helperMat);
          helper.name = light.name + ' (可视化)';
          helper.userData.isLightHelper = true;
          light.add(helper);
          
          // 外圈发光效果（更大更容易选中）
          const glowGeo = new THREE.SphereGeometry(0.35, 16, 16);
          const glowMat = new THREE.MeshBasicMaterial({ 
            color: color, 
            transparent: true, 
            opacity: 0.3,
            wireframe: true
          });
          const glow = new THREE.Mesh(glowGeo, glowMat);
          glow.name = light.name + ' (发光圈)';
          glow.userData.isLightHelper = true;
          light.add(glow);
          
          // 不可见的点击检测区域（最大，确保容易选中）
          const hitGeo = new THREE.SphereGeometry(0.6, 8, 8);
          const hitMat = new THREE.MeshBasicMaterial({ 
            visible: false,
            transparent: true,
            opacity: 0
          });
          const hitMesh = new THREE.Mesh(hitGeo, hitMat);
          hitMesh.name = light.name + ' (点击区)';
          hitMesh.userData.isLightHitBox = true;
          hitMesh.userData.parentLight = light;
          light.add(hitMesh);
          
          // 为聚光灯添加锥形指示器
          if (type === 'spot') {
            const coneGeo = new THREE.ConeGeometry(Math.tan(light.angle) * 2, 2, 32, 1, true);
            const coneMat = new THREE.MeshBasicMaterial({ 
              color: color, 
              transparent: true, 
              opacity: 0.1,
              wireframe: true
            });
            const cone = new THREE.Mesh(coneGeo, coneMat);
            cone.rotation.x = -Math.PI / 2;
            cone.position.z = 1;
            cone.name = light.name + ' (范围)';
            cone.userData.isLightHelper = true;
            light.add(cone);
          }
          
          // 为点光源添加球形范围指示器
          if (type === 'point') {
            const sphereGeo = new THREE.SphereGeometry(light.distance, 32, 16);
            const sphereMat = new THREE.MeshBasicMaterial({
              color: color,
              transparent: true,
              opacity: 0.05,
              wireframe: true
            });
            const sphere = new THREE.Mesh(sphereGeo, sphereMat);
            sphere.name = light.name + ' (范围)';
            sphere.userData.isLightHelper = true;
            light.add(sphere);
          }
          
          // 为区域光添加矩形指示器
          if (type === 'rect') {
            const rectHelper = new RectAreaLightHelper(light, color);
            rectHelper.name = light.name + ' (辅助)';
            rectHelper.userData.isLightHelper = true;
            light.add(rectHelper);
          }
        }
        
        this.scene.add(light);
        this.lights.push(light);
        this.objects.push(light);
        this.executeCommand(new AddObjectCmd(this, light));
        this.updateLightList();
        this.select(light);
        return light;
      }
      
      getLightDefaultName(type) {
        const typeNames = {
          point: '点光源',
          spot: '聚光灯',
          directional: '平行光',
          ambient: '环境光',
          hemisphere: '半球光',
          rect: '矩形光'
        };
        const count = this.lights.filter(l => l.userData.lightType === type).length + 1;
        return `${typeNames[type] || '光源'} ${count}`;
      }
      
      addLight() {
        // 随机选择一种灯光类型（向后兼容）
        const types = ['point', 'spot', 'directional'];
        const type = types[Math.floor(Math.random() * types.length)];
        this.createLight(type);
      }
      
      updateLightList() {
        const list = document.getElementById('light-list');
        if (!list) return;
        
        if (this.lights.length === 0) {
          list.innerHTML = '<div class="empty-state">暂无灯光</div>';
          return;
        }
        
        const typeIcons = {
          point: '💡',
          spot: '🔦',
          directional: '☀️',
          ambient: '🌅',
          hemisphere: '🌈',
          rect: '⬜'
        };
        
        const typeLabels = {
          point: '点光源',
          spot: '聚光灯',
          directional: '平行光',
          ambient: '环境光',
          hemisphere: '半球光',
          rect: '矩形光'
        };
        
        let html = '';
        this.lights.forEach((light, index) => {
          const selected = light === this.selected ? 'selected' : '';
          const type = light.userData.lightType || 'point';
          html += `
            <div class="light-item ${selected}" onclick="editor.selectLight(${index})">
              <span class="light-icon">${typeIcons[type]}</span>
              <div class="light-info">
                <div class="light-name">${light.name}</div>
                <div class="light-type-label">${typeLabels[type]}</div>
              </div>
              <div class="material-actions">
                <button onclick="event.stopPropagation();editor.deleteLight(${index})">✕</button>
              </div>
            </div>
          `;
        });
        list.innerHTML = html;
      }
      
      selectLight(index) {
        const light = this.lights[index];
        if (light) {
          this.select(light);
        }
      }
      
      deleteLight(index) {
        const light = this.lights[index];
        if (!light) return;
        
        if (confirm(`确定要删除 "${light.name}" 吗？`)) {
          this.scene.remove(light);
          this.lights.splice(index, 1);
          
          const objIndex = this.objects.indexOf(light);
          if (objIndex > -1) {
            this.objects.splice(objIndex, 1);
          }
          
          if (this.selected === light) {
            this.select(null);
          }
          
          this.updateLightList();
          this.updateTree();
        }
      }
      
      updateLightPanel() {
        const panel = document.getElementById('light-params');
        const emptyState = document.getElementById('light-empty');
        
        if (!panel || !this.selected || !this.selected.isLight) {
          if (panel) panel.style.display = 'none';
          if (emptyState) emptyState.style.display = 'block';
          return;
        }
        
        if (panel) panel.style.display = 'block';
        if (emptyState) emptyState.style.display = 'none';
        const light = this.selected;
        const type = light.userData.lightType || 'point';
        
        // 更新基础参数
        document.getElementById('light-type').value = type;
        document.getElementById('light-color').value = '#' + light.color.getHexString();
        document.getElementById('light-intensity').value = light.intensity;
        document.getElementById('val-light-intensity').textContent = light.intensity.toFixed(1);
        
        // 阴影参数（只有部分灯光支持）
        const canCastShadow = ['spot', 'directional', 'point'].includes(type);
        const shadowRow = document.getElementById('light-cast-shadow')?.parentElement?.parentElement;
        const shadowParams = document.getElementById('shadow-params');
        
        if (shadowRow) shadowRow.style.display = canCastShadow ? 'flex' : 'none';
        if (shadowParams) shadowParams.style.display = canCastShadow ? 'block' : 'none';
        
        if (canCastShadow) {
          const castShadow = light.castShadow || false;
          document.getElementById('light-cast-shadow').checked = castShadow;
          shadowParams.style.opacity = castShadow ? '1' : '0.5';
          shadowParams.style.pointerEvents = castShadow ? 'auto' : 'none';
          
          if (castShadow && light.shadow) {
            const size = light.shadow.mapSize.width;
            document.getElementById('light-shadow-size').value = size;
            document.getElementById('light-shadow-bias').value = light.shadow.bias || -0.001;
            document.getElementById('val-shadow-bias').textContent = (light.shadow.bias || -0.001).toFixed(4);
          }
        }
        
        // 特定灯光类型的参数
        const specificDiv = document.getElementById('light-specific-params');
        let specificHTML = '';
        
        if (type === 'spot') {
          specificHTML += `
            <div class="prop-row">
              <span class="prop-label">角度</span>
              <input type="range" min="0" max="90" value="${(light.angle * 180 / Math.PI).toFixed(0)}" 
                oninput="editor.updateLightSpecific('angle', this.value)" step="1">
              <span class="prop-value">${(light.angle * 180 / Math.PI).toFixed(0)}°</span>
            </div>
            <div class="prop-row">
              <span class="prop-label">半影</span>
              <input type="range" min="0" max="1" value="${light.penumbra}" 
                oninput="editor.updateLightSpecific('penumbra', this.value)" step="0.01">
              <span class="prop-value">${light.penumbra.toFixed(2)}</span>
            </div>
            <div class="prop-row">
              <span class="prop-label">距离</span>
              <input type="range" min="0" max="100" value="${light.distance}" 
                oninput="editor.updateLightSpecific('distance', this.value)" step="0.1">
              <span class="prop-value">${light.distance.toFixed(1)}</span>
            </div>
          `;
        } else if (type === 'point') {
          specificHTML += `
            <div class="prop-row">
              <span class="prop-label">距离</span>
              <input type="range" min="0" max="100" value="${light.distance}" 
                oninput="editor.updateLightSpecific('distance', this.value)" step="0.1">
              <span class="prop-value">${light.distance.toFixed(1)}</span>
            </div>
            <div class="prop-row">
              <span class="prop-label">衰减</span>
              <input type="range" min="0" max="3" value="${light.decay}" 
                oninput="editor.updateLightSpecific('decay', this.value)" step="0.1">
              <span class="prop-value">${light.decay.toFixed(1)}</span>
            </div>
          `;
        } else if (type === 'rect') {
          specificHTML += `
            <div class="prop-row">
              <span class="prop-label">宽度</span>
              <input type="range" min="0.1" max="20" value="${light.width}" 
                oninput="editor.updateLightSpecific('width', this.value)" step="0.1">
              <span class="prop-value">${light.width.toFixed(1)}</span>
            </div>
            <div class="prop-row">
              <span class="prop-label">高度</span>
              <input type="range" min="0.1" max="20" value="${light.height}" 
                oninput="editor.updateLightSpecific('height', this.value)" step="0.1">
              <span class="prop-value">${light.height.toFixed(1)}</span>
            </div>
          `;
        } else if (type === 'hemisphere') {
          specificHTML += `
            <div class="prop-row">
              <span class="prop-label">地面颜色</span>
              <div class="prop-input">
                <input type="color" value="#${light.groundColor.getHexString()}" 
                  oninput="editor.updateLightSpecific('groundColor', this.value)">
              </div>
            </div>
          `;
        }
        
        specificDiv.innerHTML = specificHTML;
      }
      
      updateLight(prop, value) {
        if (!this.selected || !this.selected.isLight) return;
        
        const light = this.selected;
        
        switch(prop) {
          case 'color':
            light.color.set(value);
            const newColor = new THREE.Color(value);
            // 更新所有辅助体颜色
            light.children.forEach(child => {
              if (child.isMesh && child.material) {
                child.material.color.copy(newColor);
              }
            });
            // 更新区域光辅助器
            if (light.userData.lightType === 'rect') {
              this.updateRectAreaHelper(light);
            }
            // 更新半球光的天空色/地面色同步
            if (light.userData.lightType === 'hemisphere') {
              // 保持原来的地面颜色，只更新天空色
            }
            break;
          case 'intensity':
            light.intensity = parseFloat(value);
            document.getElementById('val-light-intensity').textContent = parseFloat(value).toFixed(1);
            break;
          case 'castShadow':
            light.castShadow = value;
            document.getElementById('shadow-params').style.opacity = value ? '1' : '0.5';
            document.getElementById('shadow-params').style.pointerEvents = value ? 'auto' : 'none';
            break;
        }
      }
      
      updateLightShadow(prop, value) {
        if (!this.selected || !this.selected.isLight || !this.selected.castShadow) return;
        
        const light = this.selected;
        
        if (prop === 'mapSize') {
          const size = parseInt(value);
          light.shadow.mapSize.width = size;
          light.shadow.mapSize.height = size;
          light.shadow.map && light.shadow.map.dispose();
          light.shadow.map = null;
        } else if (prop === 'bias') {
          light.shadow.bias = parseFloat(value);
          document.getElementById('val-shadow-bias').textContent = parseFloat(value).toFixed(4);
        }
      }
      
      updateLightSpecific(prop, value) {
        if (!this.selected || !this.selected.isLight) return;
        
        const light = this.selected;
        
        switch(prop) {
          case 'angle':
            light.angle = parseFloat(value) * Math.PI / 180;
            this.updateSpotLightCone(light);
            break;
          case 'penumbra':
            light.penumbra = parseFloat(value);
            break;
          case 'distance':
            light.distance = parseFloat(value);
            this.updateLightRangeIndicator(light);
            break;
          case 'decay':
            light.decay = parseFloat(value);
            break;
          case 'width':
            light.width = parseFloat(value);
            this.updateRectAreaHelper(light);
            break;
          case 'height':
            light.height = parseFloat(value);
            this.updateRectAreaHelper(light);
            break;
          case 'groundColor':
            light.groundColor.set(value);
            break;
        }
        
        // 刷新面板显示
        this.updateLightPanel();
      }
      
      updateSpotLightCone(light) {
        const cone = light.children.find(c => c.name.includes('范围'));
        if (cone) {
          light.remove(cone);
          const coneGeo = new THREE.ConeGeometry(Math.tan(light.angle) * 2, 2, 32, 1, true);
          const coneMat = new THREE.MeshBasicMaterial({ 
            color: light.color, 
            transparent: true, 
            opacity: 0.1,
            wireframe: true
          });
          const newCone = new THREE.Mesh(coneGeo, coneMat);
          newCone.rotation.x = -Math.PI / 2;
          newCone.position.z = 1;
          newCone.name = light.name + ' (范围)';
          light.add(newCone);
        }
      }
      
      updateLightRangeIndicator(light) {
        const indicator = light.children.find(c => c.name.includes('范围'));
        if (indicator && light.userData.lightType === 'point') {
          light.remove(indicator);
          const sphereGeo = new THREE.SphereGeometry(light.distance, 32, 16);
          const sphereMat = new THREE.MeshBasicMaterial({
            color: light.color,
            transparent: true,
            opacity: 0.05,
            wireframe: true
          });
          const newSphere = new THREE.Mesh(sphereGeo, sphereMat);
          newSphere.name = light.name + ' (范围)';
          light.add(newSphere);
        }
      }
      
      updateRectAreaHelper(light) {
        // 移除旧的辅助器并添加新的
        const oldHelper = light.children.find(c => c.name.includes('辅助'));
        if (oldHelper) {
          light.remove(oldHelper);
        }
        const newHelper = new RectAreaLightHelper(light, light.color);
        newHelper.name = light.name + ' (辅助)';
        light.add(newHelper);
      }
      
      updateLightType(type) {
        if (!this.selected || !this.selected.isLight) return;
        
        const oldLight = this.selected;
        const params = {
          color: oldLight.color,
          intensity: oldLight.intensity,
          name: oldLight.name,
          x: oldLight.position.x,
          y: oldLight.position.y,
          z: oldLight.position.z,
          castShadow: oldLight.castShadow
        };
        
        // 删除旧灯光
        this.scene.remove(oldLight);
        const index = this.lights.indexOf(oldLight);
        if (index > -1) this.lights.splice(index, 1);
        const objIndex = this.objects.indexOf(oldLight);
        if (objIndex > -1) this.objects.splice(objIndex, 1);
        
        // 创建新灯光
        const newLight = this.createLight(type, params);
        this.select(newLight);
      }

      // 粒子系统
      addParticle(type) {
        const group = new THREE.Group();
        group.position.set((Math.random()-0.5)*3, 1, (Math.random()-0.5)*3);
        
        const colors = {
          fire: [0xff5500, 0xff0000],
          smoke: [0x888888, 0x444444],
          explosion: [0xffff00, 0xff0000],
          magic: [0x00ffff, 0xff00ff],
          spark: [0xffffaa, 0xffaa00],
          rain: [0xaaccff, 0x6699ff]
        };
        
        const c = colors[type] || [0xffffff, 0xffffff];
        
        for (let i = 0; i < 50; i++) {
          const geo = new THREE.SphereGeometry(0.03 + Math.random() * 0.05, 4, 4);
          const mat = new THREE.MeshBasicMaterial({ color: c[Math.floor(Math.random() * 2)] });
          const mesh = new THREE.Mesh(geo, mat);
          mesh.position.set((Math.random()-0.5)*0.5, Math.random()*0.5, (Math.random()-0.5)*0.5);
          mesh.userData = {
            velocity: new THREE.Vector3((Math.random()-0.5)*0.5, Math.random()*0.5, (Math.random()-0.5)*0.5),
            life: Math.random() * 2 + 1
          };
          group.add(mesh);
        }
        
        group.userData = { isParticle: true, particles: group.children };
        this.scene.add(group);
        this.particleSystems.push(group);
        
        if (type === 'explosion') {
          setTimeout(() => this.removeParticle(group), 1000);
        }
      }

      updateParticles() {
        this.particleSystems.forEach(group => {
          group.userData.particles.forEach(p => {
            p.position.add(p.userData.velocity);
            p.userData.life -= 0.016;
            p.material.opacity = Math.max(0, p.userData.life / 2);
            p.material.transparent = true;
          });
        });
      }

      burstParticles() {
        this.addParticle('explosion');
      }

      clearParticles() {
        this.particleSystems.forEach(group => this.scene.remove(group));
        this.particleSystems = [];
      }

      removeParticle(group) {
        this.scene.remove(group);
        this.particleSystems = this.particleSystems.filter(g => g !== group);
      }

      // 选择和变换
      select(obj) {
        this.selected = obj;
        
        // 重置材质选择状态
        if (obj && obj.userData && obj.userData.isImportedModel) {
          // 导入模型默认选中第一个材质
          this.selectedMaterialIndex = 0;
        } else {
          this.selectedMaterialIndex = undefined;
        }
        
        if (obj) {
          this.transformCtrl.attach(obj);
          this.transformCtrl.visible = true;
        } else {
          this.transformCtrl.detach();
          this.transformCtrl.visible = false;
        }
        this.updateInputs();
        this.updateTree();
        this.updateLightPanel();
        this.updateLightList();
        
        // 同步材质编辑器
        if (this.materialEditor) {
          this.materialEditor.syncFromSelection();
        }
        
        // 更新材质赋予按钮状态
        const assignDiv = document.getElementById('material-assign-buttons');
        if (assignDiv) {
          assignDiv.style.opacity = obj ? '1' : '0.5';
          assignDiv.style.pointerEvents = obj ? 'auto' : 'none';
        }
      }

      // 相机聚焦到对象
      focusOnObject(obj) {
        if (!obj) return;
        
        // 计算对象的包围盒
        const box = new THREE.Box3().setFromObject(obj);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        
        // 计算合适的相机距离
        const maxDim = Math.max(size.x, size.y, size.z);
        const distance = maxDim * 2.5;
        
        // 计算相机位置（从斜上方视角）
        const offset = new THREE.Vector3(1, 0.8, 1).normalize().multiplyScalar(distance);
        const targetPos = center.clone().add(offset);
        
        // 获取当前相机和目标位置
        const startPos = this.camera.position.clone();
        const startTarget = this.controls.target.clone();
        
        // 使用 GSAP 或简单的动画来平滑过渡
        const duration = 800;
        const startTime = Date.now();
        
        const animateCamera = () => {
          const elapsed = Date.now() - startTime;
          const t = Math.min(elapsed / duration, 1);
          // 使用 ease-out 缓动
          const ease = 1 - Math.pow(1 - t, 3);
          
          // 插值相机位置
          this.camera.position.lerpVectors(startPos, targetPos, ease);
          this.controls.target.lerpVectors(startTarget, center, ease);
          this.controls.update();
          
          if (t < 1) {
            requestAnimationFrame(animateCamera);
          }
        };
        
        animateCamera();
      }

      setTool(mode) {
        this.transformCtrl.setMode(mode);
        document.querySelectorAll('#viewport-tools button').forEach(b => b.classList.remove('active'));
        document.getElementById('tool-' + mode).classList.add('active');
      }

      toggleSpace() {
        const current = this.transformCtrl.space;
        const next = current === 'local' ? 'world' : 'local';
        this.transformCtrl.setSpace(next);
        document.getElementById('tool-local').textContent = next === 'local' ? '⊕' : '⊙';
      }

      deleteSelected() {
        if (this.selected) {
          // 如果是灯光，从灯光列表中移除
          if (this.selected.isLight) {
            const lightIndex = this.lights.indexOf(this.selected);
            if (lightIndex > -1) {
              this.lights.splice(lightIndex, 1);
            }
            this.updateLightList();
          }
          
          this.scene.remove(this.selected);
          this.objects = this.objects.filter(o => o !== this.selected);
          this.select(null);
          this.updateTree();
        }
      }
      
      // ============================================
      // 节点编辑器方法
      // ============================================
      
      addNode(type) {
        if (this.nodeEditor) {
          const x = 100 + Math.random() * 200;
          const y = 50 + Math.random() * 150;
          this.nodeEditor.addNode(type, x, y);
        }
      }
      
      showNodeEditor() {
        const panel = document.getElementById('node-editor-panel');
        if (panel) {
          panel.style.display = 'block';
          if (this.nodeEditor) {
            this.nodeEditor.resize();
          }
        }
      }
      
      hideNodeEditor() {
        const panel = document.getElementById('node-editor-panel');
        if (panel) {
          panel.style.display = 'none';
        }
      }
      
      applyNodeMaterial() {
        if (!this.nodeEditor || !this.selected) return;
        
        const material = this.nodeEditor.compile();
        if (material && this.selected.isMesh) {
          this.selected.material = material;
          this.updateInputs();
          alert('节点材质已应用');
        }
      }

      // 属性更新
      updateInputs() {
        if (!this.selected) {
          ['pos-x','pos-y','pos-z','rot-x','rot-y','rot-z','scale-x','scale-y','scale-z']
            .forEach(id => document.getElementById(id).value = id.startsWith('scale') ? 1 : 0);
          // 更新动态属性面板
          this.updateDynamicProperties();
          return;
        }
        const set = (id, v) => document.getElementById(id).value = v.toFixed(2);
        set('pos-x', this.selected.position.x);
        set('pos-y', this.selected.position.y);
        set('pos-z', this.selected.position.z);
        set('rot-x', this.selected.rotation.x * 180 / Math.PI);
        set('rot-y', this.selected.rotation.y * 180 / Math.PI);
        set('rot-z', this.selected.rotation.z * 180 / Math.PI);
        set('scale-x', this.selected.scale.x);
        set('scale-y', this.selected.scale.y);
        set('scale-z', this.selected.scale.z);
        
        // 更新动态属性面板
        this.updateDynamicProperties();
      }
      
      // 更新动态属性面板
      updateDynamicProperties() {
        const objInfoText = document.getElementById('obj-info-text');
        const objInfoType = document.getElementById('obj-info-type');
        const propsMesh = document.getElementById('props-mesh');
        const propsModel = document.getElementById('props-model');
        const propsChild = document.getElementById('props-child');
        const propsEmpty = document.getElementById('props-material-empty');
        
        if (!this.selected) {
          if (objInfoText) objInfoText.textContent = '未选择对象';
          if (objInfoType) objInfoType.textContent = '';
          if (propsMesh) propsMesh.style.display = 'none';
          if (propsModel) propsModel.style.display = 'none';
          if (propsChild) propsChild.style.display = 'none';
          if (propsEmpty) propsEmpty.style.display = 'block';
          return;
        }
        
        const obj = this.selected;
        const parentModel = this.getSelectedParentModel();
        
        // 更新对象信息
        if (objInfoText) objInfoText.textContent = obj.name || '未命名';
        
        // 确定对象类型并显示相应面板
        if (obj.isLight) {
          // 灯光 - 只显示对象信息
          if (objInfoType) objInfoType.textContent = '💡 灯光';
          if (propsMesh) propsMesh.style.display = 'none';
          if (propsModel) propsModel.style.display = 'none';
          if (propsChild) propsChild.style.display = 'none';
          if (propsEmpty) propsEmpty.style.display = 'block';
        } 
        else if (obj.userData?.isImportedModel) {
          // 导入的模型
          if (objInfoType) objInfoType.textContent = '📦 导入模型';
          if (propsMesh) propsMesh.style.display = 'none';
          if (propsModel) propsModel.style.display = 'block';
          if (propsChild) propsChild.style.display = 'none';
          if (propsEmpty) propsEmpty.style.display = 'none';
          
          // 更新模型材质列表和属性
          this.updateModelMaterialProps();
        }
        else if (parentModel) {
          // 子物体
          if (objInfoType) objInfoType.textContent = '🔹 子物体 (网格)';
          if (propsMesh) propsMesh.style.display = 'none';
          if (propsModel) propsModel.style.display = 'none';
          if (propsChild) propsChild.style.display = 'block';
          if (propsEmpty) propsEmpty.style.display = 'none';
          
          // 更新父模型名称
          const parentNameEl = document.getElementById('child-parent-name');
          if (parentNameEl) parentNameEl.textContent = parentModel.name;
          
          // 更新子物体材质属性
          this.updateChildMaterialProps();
        }
        else if (obj.isMesh) {
          // 普通网格
          if (objInfoType) objInfoType.textContent = '🎲 网格';
          if (propsMesh) propsMesh.style.display = 'block';
          if (propsModel) propsModel.style.display = 'none';
          if (propsChild) propsChild.style.display = 'none';
          if (propsEmpty) propsEmpty.style.display = 'none';
          
          // 更新网格材质属性
          this.updateMeshMaterialProps();
        }
        else {
          // 其他类型
          if (objInfoType) objInfoType.textContent = '📄 对象';
          if (propsMesh) propsMesh.style.display = 'none';
          if (propsModel) propsModel.style.display = 'none';
          if (propsChild) propsChild.style.display = 'none';
          if (propsEmpty) propsEmpty.style.display = 'block';
        }
      }
      
      // 更新网格材质属性显示
      updateMeshMaterialProps() {
        if (!this.selected || !this.selected.isMesh) return;
        
        const mat = this.selected.material;
        if (!mat) return;
        
        const colorInput = document.getElementById('mesh-mat-color');
        const emissiveInput = document.getElementById('mesh-mat-emissive');
        const roughnessInput = document.getElementById('mesh-mat-roughness');
        const metalnessInput = document.getElementById('mesh-mat-metalness');
        
        if (colorInput) colorInput.value = '#' + mat.color.getHexString();
        if (emissiveInput && mat.emissive) emissiveInput.value = '#' + mat.emissive.getHexString();
        if (roughnessInput) roughnessInput.value = mat.roughness ?? 0.5;
        if (metalnessInput) metalnessInput.value = mat.metalness ?? 0;
        
        const roughnessVal = document.getElementById('mesh-val-roughness');
        const metalnessVal = document.getElementById('mesh-val-metalness');
        if (roughnessVal) roughnessVal.textContent = (mat.roughness ?? 0.5).toFixed(2);
        if (metalnessVal) metalnessVal.textContent = (mat.metalness ?? 0).toFixed(2);
      }
      
      // 更新模型材质属性显示
      updateModelMaterialProps() {
        if (!this.selected?.userData?.isImportedModel) return;
        
        const materials = this.selected.userData.materials || [];
        const listContainer = document.getElementById('model-mat-list');
        
        // 更新材质列表
        if (listContainer) {
          if (materials.length === 0) {
            listContainer.innerHTML = '<div style="padding:8px 16px;font-size:11px;color:#666;">无材质</div>';
          } else {
            let html = '<div style="padding:8px 16px;font-size:10px;color:#666;background:#252526;border-bottom:1px solid #333;">材质列表</div>';
            materials.forEach((mat, idx) => {
              const isSelected = this.selectedMaterialIndex === idx;
              const color = mat.color ? '#' + mat.color.getHexString() : '#888';
              html += `
                <div onclick="editor.selectModelMaterial(${idx})" 
                     style="padding:8px 16px;display:flex;align-items:center;gap:8px;cursor:pointer;border-bottom:1px solid #333;${isSelected ? 'background:rgba(14,99,156,0.2);' : ''}">
                  <div style="width:20px;height:20px;border-radius:3px;border:1px solid #444;background:${color};"></div>
                  <div style="flex:1;font-size:11px;color:#ddd;overflow:hidden;text-overflow:ellipsis;">${mat.name || '材质 ' + (idx + 1)}</div>
                </div>
              `;
            });
            listContainer.innerHTML = html;
          }
        }
        
        // 更新选中材质的属性
        const matIndex = this.selectedMaterialIndex ?? 0;
        const mat = materials[matIndex];
        if (!mat) return;
        
        const colorInput = document.getElementById('model-mat-color');
        const roughnessInput = document.getElementById('model-mat-roughness');
        const metalnessInput = document.getElementById('model-mat-metalness');
        
        if (colorInput) colorInput.value = '#' + mat.color.getHexString();
        if (roughnessInput) roughnessInput.value = mat.roughness ?? 0.5;
        if (metalnessInput) metalnessInput.value = mat.metalness ?? 0;
        
        const roughnessVal = document.getElementById('model-val-roughness');
        const metalnessVal = document.getElementById('model-val-metalness');
        if (roughnessVal) roughnessVal.textContent = (mat.roughness ?? 0.5).toFixed(2);
        if (metalnessVal) metalnessVal.textContent = (mat.metalness ?? 0).toFixed(2);
      }
      
      // 更新子物体材质属性显示
      updateChildMaterialProps() {
        if (!this.selected || !this.selected.isMesh) return;
        
        const mat = this.selected.material;
        if (!mat) return;
        
        const colorInput = document.getElementById('child-mat-color');
        const roughnessInput = document.getElementById('child-mat-roughness');
        const metalnessInput = document.getElementById('child-mat-metalness');
        
        if (colorInput) colorInput.value = '#' + mat.color.getHexString();
        if (roughnessInput) roughnessInput.value = mat.roughness ?? 0.5;
        if (metalnessInput) metalnessInput.value = mat.metalness ?? 0;
        
        const roughnessVal = document.getElementById('child-val-roughness');
        const metalnessVal = document.getElementById('child-val-metalness');
        if (roughnessVal) roughnessVal.textContent = (mat.roughness ?? 0.5).toFixed(2);
        if (metalnessVal) metalnessVal.textContent = (mat.metalness ?? 0).toFixed(2);
      }
      
      // 更新网格材质
      updateMeshMaterial(prop, value) {
        if (!this.selected || !this.selected.isMesh) return;
        
        const mat = this.selected.material;
        if (!mat) return;
        
        if (prop === 'color' || prop === 'emissive') {
          mat[prop].set(value);
        } else {
          mat[prop] = parseFloat(value);
          if (prop === 'roughness') {
            document.getElementById('mesh-val-roughness').textContent = parseFloat(value).toFixed(2);
          } else if (prop === 'metalness') {
            document.getElementById('mesh-val-metalness').textContent = parseFloat(value).toFixed(2);
          }
        }
        mat.needsUpdate = true;
      }
      
      // 更新模型材质
      updateModelMaterial(prop, value) {
        if (!this.selected?.userData?.isImportedModel) return;
        
        const materials = this.selected.userData.materials || [];
        const matIndex = this.selectedMaterialIndex ?? 0;
        const mat = materials[matIndex];
        if (!mat) return;
        
        if (prop === 'color') {
          mat.color.set(value);
        } else {
          mat[prop] = parseFloat(value);
          if (prop === 'roughness') {
            document.getElementById('model-val-roughness').textContent = parseFloat(value).toFixed(2);
          } else if (prop === 'metalness') {
            document.getElementById('model-val-metalness').textContent = parseFloat(value).toFixed(2);
          }
        }
        
        // 更新应用到所有使用此材质的子网格
        this.selected.traverse(child => {
          if (child.isMesh && child.material === mat) {
            child.material.needsUpdate = true;
          }
        });
        
        // 刷新材质列表显示
        this.updateModelMaterialProps();
      }
      
      // 更新子物体材质
      updateChildMaterial(prop, value) {
        if (!this.selected || !this.selected.isMesh) return;
        
        const mat = this.selected.material;
        if (!mat) return;
        
        if (prop === 'color') {
          mat.color.set(value);
        } else {
          mat[prop] = parseFloat(value);
          if (prop === 'roughness') {
            document.getElementById('child-val-roughness').textContent = parseFloat(value).toFixed(2);
          } else if (prop === 'metalness') {
            document.getElementById('child-val-metalness').textContent = parseFloat(value).toFixed(2);
          }
        }
        mat.needsUpdate = true;
      }
      
      // 为网格导入贴图
      importTextureForMesh() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.onchange = async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          
          try {
            const reader = new FileReader();
            reader.onload = async (event) => {
              const textureLoader = new THREE.TextureLoader();
              const texture = await textureLoader.loadAsync(event.target.result);
              texture.colorSpace = THREE.SRGBColorSpace;
              
              if (this.selected?.isMesh && this.selected.material) {
                this.selected.material.map = texture;
                this.selected.material.needsUpdate = true;
                alert(`贴图 "${file.name}" 已导入`);
              }
            };
            reader.readAsDataURL(file);
          } catch (err) {
            alert('贴图导入失败: ' + err.message);
          }
        };
        input.click();
      }
      
      // 更新导入模型的材质列表
      updateModelMaterialsList() {
        const listDiv = document.getElementById('model-materials-list');
        const contentDiv = document.getElementById('model-materials-content');
        
        // 获取父级模型（如果是子物体，则获取其父级）
        const parentModel = this.getSelectedParentModel();
        
        if (!parentModel || !parentModel.userData || !parentModel.userData.isImportedModel) {
          if (listDiv) listDiv.style.display = 'none';
          return;
        }
        
        const materials = parentModel.userData.materials || [];
        if (materials.length === 0) {
          if (listDiv) listDiv.style.display = 'none';
          return;
        }
        
        if (listDiv) {
          listDiv.style.display = 'block';
          // 如果是子物体，添加提示
          if (this.selected !== parentModel) {
            const label = listDiv.querySelector('div:first-child');
            if (label) label.textContent = `模型材质列表 (来自: ${parentModel.name})`;
          }
        }
        
        let html = '';
        materials.forEach((mat, index) => {
          const isSelected = this.selectedMaterialIndex === index;
          const color = mat.color ? '#' + mat.color.getHexString() : '#888';
          html += `
            <div class="material-item ${isSelected ? 'selected' : ''}" 
                 onclick="editor.selectModelMaterial(${index})"
                 style="padding:8px 12px;display:flex;align-items:center;gap:8px;cursor:pointer;border-bottom:1px solid #333;${isSelected ? 'background:rgba(14,99,156,0.2);' : ''}">
              <div style="width:24px;height:24px;border-radius:4px;border:1px solid #444;background:${color};"></div>
              <div style="flex:1;font-size:11px;color:#ddd;">${mat.name || '材质 ' + (index + 1)}</div>
              <div style="font-size:10px;color:#666;">${mat.type || 'Standard'}</div>
            </div>
          `;
        });
        
        if (contentDiv) contentDiv.innerHTML = html;
      }
      
      // 选择导入模型的特定材质进行编辑
      selectModelMaterial(index) {
        this.selectedMaterialIndex = index;
        this.updateModelMaterialProps();
      }
      
      // 更新子网格材质分配面板
      updateMeshMaterialAssign() {
        const panel = document.getElementById('mesh-material-assign');
        const content = document.getElementById('mesh-material-content');
        
        if (!this.selected) {
          if (panel) panel.style.display = 'none';
          return;
        }
        
        // 获取父级模型（处理子物体的情况）
        const parentModel = this.getSelectedParentModel() || this.selected;
        
        // 收集所有子网格
        const meshes = [];
        if (parentModel.isMesh) {
          meshes.push(parentModel);
        }
        parentModel.traverse((child) => {
          if (child.isMesh) meshes.push(child);
        });
        
        if (meshes.length === 0) {
          if (panel) panel.style.display = 'none';
          return;
        }
        
        if (panel) {
          panel.style.display = 'block';
          // 更新面板标题
          const title = panel.querySelector('div:first-child');
          if (title) {
            if (this.selected !== parentModel) {
              title.textContent = `子网格材质分配 (来自: ${parentModel.name})`;
            } else {
              title.textContent = '子网格材质分配';
            }
          }
        }
        
        // 获取可用材质列表（包括材质库和模型的材质）
        const availableMaterials = this.getAvailableMaterials();
        
        let html = '';
        meshes.forEach((mesh, idx) => {
          const matName = mesh.material?.name || '未命名材质';
          const matColor = mesh.material?.color ? '#' + mesh.material.color.getHexString() : '#888';
          
          html += `
            <div style="padding:6px 0;border-bottom:1px solid #333;">
              <div style="font-size:10px;color:#888;margin-bottom:4px;">${mesh.name || '网格 ' + (idx + 1)}</div>
              <div style="display:flex;align-items:center;gap:6px;">
                <div style="width:16px;height:16px;border-radius:3px;border:1px solid #444;background:${matColor};"></div>
                <select onchange="editor.assignMaterialToMesh('${mesh.uuid}', this.value)" 
                        style="flex:1;padding:4px 6px;background:#3c3c3c;border:1px solid #444;border-radius:3px;color:#ddd;font-size:10px;">
                  <option value="">当前: ${matName}</option>
                  ${availableMaterials.map(m => `<option value="${m.id}">${m.name}</option>`).join('')}
                </select>
              </div>
            </div>
          `;
        });
        
        if (content) content.innerHTML = html;
      }
      
      // 获取所有可用材质
      getAvailableMaterials() {
        const materials = [];
        
        // 从材质库获取
        if (this.materialLibrary) {
          this.materialLibrary.materials.forEach((matData, id) => {
            materials.push({ id, name: matData.name });
          });
        }
        
        // 从当前选中模型的材质获取（支持子物体）
        const parentModel = this.getSelectedParentModel() || this.selected;
        if (parentModel?.userData?.materials) {
          parentModel.userData.materials.forEach((mat, idx) => {
            materials.push({ id: 'model_' + idx, name: mat.name || '模型材质 ' + (idx + 1) });
          });
        }
        
        return materials;
      }
      
      // 为特定网格分配材质
      assignMaterialToMesh(meshUuid, materialId) {
        // 获取父级模型（处理子物体的情况）
        const parentModel = this.getSelectedParentModel() || this.selected;
        if (!parentModel) return;
        
        // 找到对应的网格
        let targetMesh = null;
        parentModel.traverse((child) => {
          if (child.isMesh && child.uuid === meshUuid) {
            targetMesh = child;
          }
        });
        
        if (!targetMesh) return;
        
        let newMaterial = null;
        
        // 从材质库查找
        if (this.materialLibrary && this.materialLibrary.materials.has(materialId)) {
          const matData = this.materialLibrary.materials.get(materialId);
          newMaterial = matData.material.clone();
        }
        // 从模型材质查找
        else if (materialId.startsWith('model_')) {
          const idx = parseInt(materialId.replace('model_', ''));
          const materials = parentModel.userData?.materials;
          if (materials && materials[idx]) {
            newMaterial = materials[idx].clone();
          }
        }
        
        if (newMaterial) {
          targetMesh.material = newMaterial;
          this.updateInputs();
        }
      }
      
      // 为选中的材质导入贴图
      async importTextureForSelected() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        
        input.onchange = async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          
          try {
            const reader = new FileReader();
            reader.onload = async (event) => {
              const textureLoader = new THREE.TextureLoader();
              const texture = await textureLoader.loadAsync(event.target.result);
              texture.colorSpace = THREE.SRGBColorSpace;
              
              // 应用到当前选中的材质
              let targetMat = null;
              const parentModel = this.getSelectedParentModel();
              
              if (parentModel?.userData?.isImportedModel && this.selectedMaterialIndex !== undefined) {
                const materials = parentModel.userData.materials;
                if (materials && materials[this.selectedMaterialIndex]) {
                  targetMat = materials[this.selectedMaterialIndex];
                }
              } else if (this.selected?.isMesh && !parentModel) {
                targetMat = this.selected.material;
              }
              
              if (targetMat) {
                targetMat.map = texture;
                targetMat.needsUpdate = true;
                alert(`贴图 "${file.name}" 已应用到材质`);
              }
            };
            reader.readAsDataURL(file);
          } catch (err) {
            alert('贴图导入失败: ' + err.message);
          }
        };
        
        input.click();
      }

      // 获取选中对象的材质（支持导入的模型和子物体）
      getSelectedMaterial() {
        if (!this.selected) return null;
        
        // 如果是单个 Mesh，直接返回材质
        if (this.selected.isMesh && this.selected.material) {
          return this.selected.material;
        }
        
        // 如果是导入的模型（Group），返回第一个找到的材质
        if (this.selected.userData && this.selected.userData.materials && this.selected.userData.materials.length > 0) {
          return this.selected.userData.materials[0];
        }
        
        // 遍历查找第一个 Mesh 的材质
        let foundMaterial = null;
        this.selected.traverse((child) => {
          if (child.isMesh && child.material && !foundMaterial) {
            foundMaterial = child.material;
          }
        });
        return foundMaterial;
      }
      
      // 获取选中对象的父级模型（如果是子物体）
      getSelectedParentModel() {
        if (!this.selected) return null;
        
        // 如果本身就是导入的模型
        if (this.selected.userData?.isImportedModel) {
          return this.selected;
        }
        
        // 如果是子物体，返回父级
        if (this.selected.userData?.parentGroup) {
          return this.selected.userData.parentGroup;
        }
        
        return null;
      }

      // ============================================
      // 材质管理器方法
      // ============================================
      
      updateMaterialList() {
        const list = document.getElementById('mat-editor-library');
        if (!list) return;
        if (!this.materialLibrary) {
          list.innerHTML = '<div style="padding:6px;font-size:10px;color:#666;">材质库未初始化</div>';
          return;
        }
        
        const materials = this.materialLibrary.getMaterialList();
        if (materials.length === 0) {
          list.innerHTML = '<div style="padding:6px;font-size:10px;color:#666;">暂无材质</div>';
          return;
        }
        
        let html = '';
        materials.forEach(mat => {
          const selected = mat.id === this.selectedMaterial ? 'selected' : '';
          html += `
            <div class="material-item ${selected}" onclick="editor.selectMaterial('${mat.id}')">
              <div class="material-preview" style="background:${mat.preview};"></div>
              <div class="material-info">
                <div class="material-name">${mat.name}</div>
                <div class="material-type">${mat.type}</div>
              </div>
              <div class="material-actions">
                <button onclick="event.stopPropagation();editor.assignMaterialToSelected('${mat.id}')">应用</button>
                <button onclick="event.stopPropagation();editor.deleteMaterial('${mat.id}')">✕</button>
              </div>
            </div>
          `;
        });
        list.innerHTML = html;
      }
      
      selectMaterial(id) {
        this.selectedMaterial = id;
        this.updateMaterialList();
        
        // 更新选中材质信息
        const matData = this.materialLibrary.materials.get(id);
        const infoDiv = document.getElementById('selected-material-info');
        if (matData && infoDiv) {
          infoDiv.innerHTML = `<strong>${matData.name}</strong> (${matData.type})`;
        }
        
        // 如果有选中对象，启用赋予按钮
        const assignDiv = document.getElementById('material-assign-buttons');
        if (assignDiv) {
          assignDiv.style.opacity = this.selected ? '1' : '0.5';
          assignDiv.style.pointerEvents = this.selected ? 'auto' : 'none';
        }
      }
      
      showCreateMaterialDialog() {
        document.getElementById('material-dialog').classList.add('active');
      }
      
      hideMaterialDialog() {
        document.getElementById('material-dialog').classList.remove('active');
      }
      
      createMaterial() {
        const name = document.getElementById('mat-name').value || '新材质';
        const type = document.getElementById('mat-type').value;
        const color = document.getElementById('mat-base-color').value;
        
        const id = this.materialLibrary.createMaterial(type, name, { 
          color: new THREE.Color(color),
          roughness: 0.5,
          metalness: 0
        });
        
        this.updateMaterialList();
        this.selectMaterial(id);
        this.hideMaterialDialog();
        
        // 重置表单
        document.getElementById('mat-name').value = '新材质';
      }
      
      deleteMaterial(id) {
        if (confirm('确定要删除这个材质吗？')) {
          this.materialLibrary.deleteMaterial(id);
          if (this.selectedMaterial === id) {
            this.selectedMaterial = null;
          }
          this.updateMaterialList();
        }
      }
      
      assignMaterialToSelected(materialId) {
        if (!this.selected) {
          alert('请先选择一个对象');
          return;
        }
        
        const success = this.materialLibrary.assignMaterial(materialId, this.selected);
        if (success) {
          this.updateInputs();
          alert('材质已应用');
        } else {
          alert('无法应用材质到该对象');
        }
      }
      
      assignSelectedMaterial() {
        if (this.selectedMaterial) {
          this.assignMaterialToSelected(this.selectedMaterial);
        }
      }
      
      importTexture() {
        document.getElementById('texture-dialog').classList.add('active');
      }
      
      hideTextureDialog() {
        document.getElementById('texture-dialog').classList.remove('active');
      }
      
      async loadTexture() {
        const fileInput = document.getElementById('tex-file');
        const type = document.getElementById('tex-type').value;
        
        if (!fileInput.files || fileInput.files.length === 0) {
          alert('请选择图片文件');
          return;
        }
        
        try {
          const file = fileInput.files[0];
          const result = await this.materialLibrary.importTexture(file, type);
          
          alert(`贴图 "${file.name}" 导入成功！`);
          this.hideTextureDialog();
          fileInput.value = '';
        } catch (err) {
          alert('贴图导入失败: ' + err.message);
        }
      }

      updateTransform() {
        if (!this.selected) return;
        const get = (id) => parseFloat(document.getElementById(id).value) || 0;
        this.selected.position.set(get('pos-x'), get('pos-y'), get('pos-z'));
        this.selected.rotation.set(get('rot-x') * Math.PI / 180, get('rot-y') * Math.PI / 180, get('rot-z') * Math.PI / 180);
        this.selected.scale.set(get('scale-x'), get('scale-y'), get('scale-z'));
      }

      updateMaterial(prop, value) {
        if (!this.selected) return;
        
        // 如果是灯光，更新灯光颜色
        if (this.selected.isLight) {
          if (prop === 'color' || prop === 'emissive') {
            this.selected.color.set(value);
            // 同时更新可视化辅助体的颜色
            this.selected.children.forEach(child => {
              if (child.isMesh && child.material) {
                child.material.color.set(value);
              }
            });
          }
          return;
        }
        
        // 获取要更新的材质列表
        const materialsToUpdate = [];
        
        // 获取父级模型（处理子物体的情况）
        const parentModel = this.getSelectedParentModel();
        
        // 如果选中了导入模型的特定材质，只更新那个材质
        if (parentModel && parentModel.userData?.isImportedModel && 
            this.selectedMaterialIndex !== undefined && 
            parentModel.userData.materials && 
            parentModel.userData.materials[this.selectedMaterialIndex]) {
          materialsToUpdate.push(parentModel.userData.materials[this.selectedMaterialIndex]);
        }
        // 如果是导入的模型但没有选中特定材质，更新所有材质
        else if (parentModel && parentModel.userData?.materials) {
          materialsToUpdate.push(...parentModel.userData.materials);
        }
        
        // 如果是单个 Mesh（不是导入模型的子物体）
        if (this.selected.isMesh && this.selected.material && !parentModel) {
          materialsToUpdate.push(this.selected.material);
        }
        
        // 遍历更新所有材质
        materialsToUpdate.forEach(material => {
          if (!material) return;
          
          if (prop === 'color' || prop === 'emissive') {
            material[prop].set(value);
          } else {
            material[prop] = parseFloat(value);
            document.getElementById('val-' + prop).textContent = parseFloat(value).toFixed(2);
          }
          material.needsUpdate = true;
        });
        
        // 更新材质列表显示（颜色可能已改变）
        this.updateModelMaterialsList();
      }

      // 后处理
      toggleBloom(enabled) {
        this.renderer.toneMappingExposure = enabled ? 1.5 : 1.0;
      }

      setBloomStrength(v) {
        document.getElementById('val-bloom-strength').textContent = v;
        this.renderer.toneMappingExposure = 1.0 + parseFloat(v) * 0.3;
      }

      applyPreset(name) {
        const presets = { cinematic: 1.3, scifi: 1.8, dreamy: 1.5, performance: 1.0, none: 1.0 };
        this.renderer.toneMappingExposure = presets[name] || 1.0;
        document.getElementById('pp-bloom').checked = name !== 'none';
      }

      // 物理控制
      togglePhysics() {
        if (!this.physics) return;
        this.isPhysicsPaused = !this.physics.paused;
        this.physics.paused = this.isPhysicsPaused;
        document.getElementById('btn-physics').textContent = this.isPhysicsPaused ? '▶️ 继续物理' : '⏸️ 暂停物理';
        document.getElementById('st-physics').textContent = this.isPhysicsPaused ? '⏸️ 物理暂停' : '⚙️ 物理运行';
      }

      toggleGrid() {
        if (this.gridHelper) {
          this.gridHelper.visible = !this.gridHelper.visible;
          const btn = document.getElementById('btn-grid');
          if (btn) {
            btn.style.background = this.gridHelper.visible ? '#3c3c3c' : '#666';
            btn.style.opacity = this.gridHelper.visible ? '1' : '0.6';
          }
        }
      }

      togglePanel(header) {
        const content = header.nextElementSibling;
        if (content && content.classList.contains('prop-group-content')) {
          header.classList.toggle('collapsed');
          content.classList.toggle('collapsed');
        }
      }

      toggleSelectMode() {
        this.selectChildMode = !this.selectChildMode;
        const btn = document.getElementById('btn-select-mode');
        if (btn) {
          if (this.selectChildMode) {
            btn.textContent = '🔹 选子体';
            btn.style.background = '#0e639c';
            btn.title = '当前：点击选择子物体';
          } else {
            btn.textContent = '📦 选整体';
            btn.style.background = '#3c3c3c';
            btn.title = '当前：点击选择整个模型';
          }
        }
      }

      // ============================================
      // Slate 材质编辑器方法
      // ============================================
      
      matEditorCreateMaterial(type) {
        if (this.materialEditor) {
          this.materialEditor.createMaterial(type);
        }
      }
      
      matEditorSelectType(type) {
        if (this.materialEditor) {
          this.materialEditor.selectType(type);
        }
      }
      
      matEditorUpdateProp(prop, value) {
        if (this.materialEditor) {
          this.materialEditor.updateProperty(prop, value);
        }
      }
      
      matEditorSelectSlot(slot) {
        if (this.materialEditor) {
          this.materialEditor.selectSlot(slot);
        }
      }
      
      matEditorImportTexture(slot) {
        if (this.materialEditor) {
          this.materialEditor.importTexture(slot);
        }
      }
      
      matEditorAddNode(type) {
        if (this.materialEditor) {
          this.materialEditor.addNode(type);
        }
      }
      
      matEditorApplyToSelected() {
        if (this.materialEditor) {
          this.materialEditor.applyToSelected();
        }
      }
      
      matEditorLoadFromLibrary(materialId) {
        if (this.materialEditor) {
          this.materialEditor.loadFromLibrary(materialId);
        }
      }

      updateGravity() {
        const val = parseFloat(document.getElementById('gravity-y').value);
        document.getElementById('val-gravity').textContent = val.toFixed(1);
        if (this.physics) {
          this.physics.world.gravity.set(0, val, 0);
        }
      }

      applyExplosion() {
        if (this.physics) {
          this.physics.applyExplosion(new THREE.Vector3(0, 0, 0), 10, 10);
        }
      }

      applyUpForce() {
        if (this.physics) {
          this.physics.applyUpForce(5);
        }
      }

      // 命令系统
      executeCommand(cmd) {
        if (this.historyIndex < this.history.length - 1) {
          this.history = this.history.slice(0, this.historyIndex + 1);
        }
        this.history.push(cmd);
        this.historyIndex++;
        this.updateHistoryButtons();
      }

      undo() {
        if (this.historyIndex < 0) return;
        this.history[this.historyIndex].undo();
        this.historyIndex--;
        this.updateHistoryButtons();
      }

      redo() {
        if (this.historyIndex >= this.history.length - 1) return;
        this.historyIndex++;
        this.history[this.historyIndex].execute();
        this.updateHistoryButtons();
      }

      updateHistoryButtons() {
        document.getElementById('btn-undo').disabled = this.historyIndex < 0;
        document.getElementById('btn-redo').disabled = this.historyIndex >= this.history.length - 1;
      }

      // 场景操作
      newScene() {
        if (!confirm('确定要新建场景？所有内容将清除。')) return;
        
        if (this.physics) this.physics.clear();
        this.clearParticles();
        
        this.objects.forEach(obj => this.scene.remove(obj));
        this.objects = [];
        this.history = [];
        this.historyIndex = -1;
        this.select(null);
        this.updateHistoryButtons();
        this.updateTree();
      }

      updateTree() {
        const tree = document.getElementById('scene-tree');
        if (this.objects.length === 0) {
          tree.innerHTML = '<div class="empty-state">暂无对象</div>';
          return;
        }
        
        let html = '';
        
        // 递归渲染树节点
        const renderNode = (obj, depth = 0, skipIfEmptyGroup = false) => {
          const selected = obj === this.selected ? 'selected' : '';
          let icon = '📄';
          if (obj.isMesh) icon = '🎲';
          else if (obj.isLight) icon = '💡';
          else if (obj.isCamera) icon = '📷';
          else if (obj.userData && obj.userData.isImportedModel) icon = '📦';
          else if (obj.type === 'Group' || obj.type === 'Object3D') icon = '📁';
          
          // 获取所有可见子物体（包括Mesh、Group等）
          const allChildren = obj.children?.filter(c => {
            // 排除辅助对象、控制器等
            return c.isMesh || c.type === 'Group' || c.type === 'Object3D';
          }) || [];
          
          // 检查是否是空的中间组（只有一个子物体且是Group/Object3D）
          const isEmptyGroup = !obj.isMesh && !obj.userData?.isImportedModel && 
                               allChildren.length === 1 && 
                               !allChildren[0].isMesh;
          
          // 如果是空的中间组且设置了跳过，直接渲染其子物体
          if (isEmptyGroup && skipIfEmptyGroup) {
            return renderNode(allChildren[0], depth, true);
          }
          
          const hasChildren = allChildren.length > 0;
          const expanded = this.expandedNodes.has(obj.uuid);
          
          // 展开/折叠图标
          let expandIcon = '';
          if (hasChildren) {
            expandIcon = expanded ? '▼' : '▶';
          } else {
            expandIcon = '•';
          }
          
          // 统计信息
          let extraInfo = '';
          if (obj.userData && obj.userData.materials) {
            extraInfo = ` (${obj.userData.materials.length}材质)`;
          }
          // 统计实际的 Mesh 子物体数量（递归）
          const countMeshes = (node) => {
            let count = 0;
            node.children?.forEach(c => {
              if (c.isMesh) count++;
              else count += countMeshes(c);
            });
            return count;
          };
          const meshCount = countMeshes(obj);
          if (meshCount > 0 && !obj.isMesh) {
            extraInfo += ` [${meshCount}子]`;
          }
          
          // 节点HTML - 点击整行都可以选择，但展开按钮除外
          let nodeHtml = '';
          
          // 只有是 Mesh 或者是导入的模型或者是根级别才显示节点
          const shouldShowNode = obj.isMesh || obj.userData?.isImportedModel || depth === 0;
          
          if (shouldShowNode) {
            nodeHtml = `
              <div class="tree-item ${selected}" style="padding-left:${8 + depth * 16}px" onclick="if(event.target.closest('.tree-expand'))return;editor.selectByUUID('${obj.uuid}')">
                <span class="tree-expand" onclick="event.stopPropagation();editor.toggleTreeExpand('${obj.uuid}')" style="cursor:pointer;margin-right:4px;display:inline-block;width:14px;">${expandIcon}</span>
                <span style="margin-right:4px;">${icon}</span>
                <span style="overflow:hidden;text-overflow:ellipsis;flex:1;">${obj.name || obj.type}${extraInfo}</span>
              </div>
            `;
          }
          
          // 递归渲染子物体 - 对导入的模型启用扁平化
          if ((expanded || depth === 0) && hasChildren) {
            // 对导入的模型启用扁平化显示
            const flatten = obj.userData?.isImportedModel || isEmptyGroup;
            allChildren.forEach(child => {
              nodeHtml += renderNode(child, shouldShowNode ? depth + 1 : depth, flatten);
            });
          }
          
          return nodeHtml;
        };
        
        // 渲染所有顶级对象
        this.objects.forEach(obj => {
          html += renderNode(obj, 0);
        });
        
        tree.innerHTML = html;
        document.getElementById('st-obj').textContent = this.objects.length + ' 对象';
      }
      
      // 切换树节点的展开/折叠状态
      toggleTreeExpand(uuid) {
        if (this.expandedNodes.has(uuid)) {
          this.expandedNodes.delete(uuid);
        } else {
          this.expandedNodes.add(uuid);
        }
        this.updateTree();
      }
      
      // 通过 UUID 选择对象（用于子物体）
      selectByUUID(uuid) {
        let found = null;
        this.scene.traverse(obj => {
          if (obj.uuid === uuid) found = obj;
        });
        if (found) this.select(found);
      }

      updateStats() {
        document.getElementById('stat-objects').textContent = this.objects.length;
        document.getElementById('stat-particles').textContent = this.particleSystems.length;
        document.getElementById('stat-bodies').textContent = this.physics ? this.physics.bodies.length : 0;
      }

      // 导入模型
      importModel() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.gltf,.glb,.obj,.fbx';
        input.onchange = async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          
          console.log('正在导入:', file.name);
          
          // 创建加载提示
          const loading = document.createElement('div');
          loading.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,0.9);color:#0e639c;padding:20px 40px;border-radius:8px;z-index:9999;font-size:14px;';
          loading.textContent = '正在加载模型...';
          document.body.appendChild(loading);
          
          try {
            const url = URL.createObjectURL(file);
            
            if (file.name.endsWith('.glb') || file.name.endsWith('.gltf')) {
              // 加载 GLTF/GLB
              const { GLTFLoader } = await import('three/addons/loaders/GLTFLoader.js');
              const loader = new GLTFLoader();
              
              loader.load(url, (gltf) => {
                const model = gltf.scene;
                model.name = file.name.replace(/\.[^/.]+$/, '');
                
                // 先更新世界矩阵确保包围盒计算正确
                model.updateMatrixWorld(true);
                
                // 计算包围盒
                const box = new THREE.Box3().setFromObject(model);
                const size = box.getSize(new THREE.Vector3());
                
                // 保持原始坐标，只在模型过大或过小时调整缩放
                const maxDim = Math.max(size.x, size.y, size.z);
                if (maxDim > 10 || maxDim < 0.01) {
                  const scale = maxDim > 10 ? 5 / maxDim : 100;
                  model.scale.setScalar(scale);
                  console.log('模型尺寸:', size.x.toFixed(2), size.y.toFixed(2), size.z.toFixed(2), '缩放:', scale.toFixed(2));
                } else {
                  console.log('模型尺寸:', size.x.toFixed(2), size.y.toFixed(2), size.z.toFixed(2), '使用原始大小');
                }
                
                // 重新计算世界矩阵
                model.updateMatrixWorld(true);
                
                // 收集所有材质并启用阴影
                const materialMap = new Map(); // 用于去重
                model.traverse((child) => {
                  if (child.isMesh) {
                    child.castShadow = true;
                    child.receiveShadow = true;
                    // 记录父级引用，用于子物体选择
                    child.userData.parentGroup = model;
                    if (child.material) {
                      // 处理材质数组的情况
                      const mats = Array.isArray(child.material) ? child.material : [child.material];
                      const newMats = mats.map(mat => {
                        // 如果已经是标准材质，直接返回
                        if (mat instanceof THREE.MeshStandardMaterial || mat instanceof THREE.MeshPhysicalMaterial) {
                          if (!mat.name) mat.name = '材质 ' + (materialMap.size + 1);
                          return mat;
                        }
                        
                        // 转换其他材质类型为标准材质
                        const oldMat = mat;
                        const newMat = new THREE.MeshStandardMaterial({
                          color: oldMat.color ? oldMat.color.clone() : 0xffffff,
                          map: oldMat.map || null,
                          roughness: oldMat.roughness !== undefined ? oldMat.roughness : 0.5,
                          metalness: oldMat.metalness !== undefined ? oldMat.metalness : 0.0,
                          name: oldMat.name || '材质 ' + (materialMap.size + 1)
                        });
                        return newMat;
                      });
                      
                      // 更新子网格的材质
                      child.material = newMats.length === 1 ? newMats[0] : newMats;
                      
                      // 收集唯一材质
                      newMats.forEach(mat => {
                        if (!materialMap.has(mat.uuid)) {
                          materialMap.set(mat.uuid, mat);
                        }
                      });
                    }
                  }
                });
                
                // 保存材质引用到模型
                const materials = Array.from(materialMap.values());
                model.userData.materials = materials;
                model.userData.isImportedModel = true;
                
                this.scene.add(model);
                this.objects.push(model);
                
                // 自动展开模型节点，显示子物体
                this.expandedNodes.add(model.uuid);
                
                this.select(model);
                this.updateTree();
                
                // 相机聚焦到模型
                this.focusOnObject(model);
                
                URL.revokeObjectURL(url);
                document.body.removeChild(loading);
                alert(`✅ 成功导入: ${file.name}\n包含 ${materials.length} 个材质`);
              }, undefined, (err) => {
                console.error(err);
                document.body.removeChild(loading);
                alert('❌ 加载失败: ' + err.message);
              });
              
            } else if (file.name.endsWith('.obj')) {
              // 加载 OBJ
              const { OBJLoader } = await import('three/addons/loaders/OBJLoader.js');
              const loader = new OBJLoader();
              
              loader.load(url, (obj) => {
                obj.name = file.name.replace(/\.[^/.]+$/, '');
                
                // 先更新世界矩阵
                obj.updateMatrixWorld(true);
                
                const box = new THREE.Box3().setFromObject(obj);
                const size = box.getSize(new THREE.Vector3());
                
                // 保持原始坐标，只在模型过大或过小时调整缩放
                const maxDim = Math.max(size.x, size.y, size.z);
                if (maxDim > 10 || maxDim < 0.01) {
                  const scale = maxDim > 10 ? 5 / maxDim : 100;
                  obj.scale.setScalar(scale);
                  console.log('OBJ模型尺寸:', size.x.toFixed(2), size.y.toFixed(2), size.z.toFixed(2), '缩放:', scale.toFixed(2));
                } else {
                  console.log('OBJ模型尺寸:', size.x.toFixed(2), size.y.toFixed(2), size.z.toFixed(2), '使用原始大小');
                }
                
                obj.updateMatrixWorld(true);
                
                // 收集所有材质
                const materialMap = new Map();
                obj.traverse((child) => {
                  if (child.isMesh) {
                    child.castShadow = true;
                    child.receiveShadow = true;
                    // 记录父级引用，用于子物体选择
                    child.userData.parentGroup = obj;
                    if (child.material) {
                      // OBJ 通常使用 MeshLambertMaterial，转换为 MeshStandardMaterial
                      if (!(child.material instanceof THREE.MeshStandardMaterial)) {
                        const oldMat = child.material;
                        child.material = new THREE.MeshStandardMaterial({
                          color: oldMat.color || 0xffffff,
                          map: oldMat.map || null,
                          roughness: 0.5,
                          metalness: 0.0,
                          name: oldMat.name || '材质'
                        });
                      }
                      // 为没有名称的材质设置默认名称
                      if (!child.material.name) {
                        child.material.name = '材质 ' + (materialMap.size + 1);
                      }
                      // 收集唯一材质
                      if (!materialMap.has(child.material.uuid)) {
                        materialMap.set(child.material.uuid, child.material);
                      }
                    }
                  }
                });
                
                const materials = Array.from(materialMap.values());
                obj.userData.materials = materials;
                obj.userData.isImportedModel = true;
                
                this.scene.add(obj);
                this.objects.push(obj);
                this.select(obj);
                this.updateTree();
                
                // 相机聚焦到模型
                this.focusOnObject(obj);
                
                URL.revokeObjectURL(url);
                document.body.removeChild(loading);
                alert(`✅ 成功导入: ${file.name}\n包含 ${materials.length} 个材质`);
              }, undefined, (err) => {
                console.error(err);
                document.body.removeChild(loading);
                alert('❌ 加载失败: ' + err.message);
              });
            } else {
              document.body.removeChild(loading);
              alert('⚠️ 不支持的文件格式');
            }
          } catch (err) {
            console.error(err);
            if (loading.parentNode) document.body.removeChild(loading);
            alert('❌ 导入失败: ' + err.message);
          }
        };
        input.click();
      }

      // 导出
      showExportDialog() {
        document.getElementById('export-dialog').classList.add('active');
      }

      hideExportDialog() {
        document.getElementById('export-dialog').classList.remove('active');
      }

      performExport() {
        const title = document.getElementById('export-title').value || 'My Scene';
        
        // 构建对象代码
        let objectsCode = '';
        this.objects.forEach(obj => {
          if (!obj.isMesh) return;
          const colorHex = obj.material && obj.material.color ? obj.material.color.getHexString() : 'ffffff';
          objectsCode += `const m=new THREE.Mesh(new THREE.BoxGeometry(1,1,1),new THREE.MeshStandardMaterial({color:0x${colorHex}}));m.position.set(${obj.position.x},${obj.position.y},${obj.position.z});scene.add(m);\n`;
        });
        
        // 构建导出HTML - 使用数组避免引号问题
        const htmlParts = [
          '<!DOCTYPE html>\n<html>\n<head>\n  <meta charset="UTF-8">\n  <title>',
          title,
          '</title>\n<style>body{margin:0;overflow:hidden;background:#000}canvas{display:block}</style>\n</head>\n<body>\n',
          '<script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js">\x3C/script>\n',
          '<script>\n',
          'const scene=new THREE.Scene();\nscene.background=new THREE.Color(0x0a0a0a);\n',
          'const camera=new THREE.PerspectiveCamera(60,innerWidth/innerHeight,0.1,1000);\n',
          'camera.position.set(5,5,5);\n',
          'const renderer=new THREE.WebGLRenderer({antialias:true});\n',
          'renderer.setSize(innerWidth,innerHeight);\n',
          'document.body.appendChild(renderer.domElement);\n',
          objectsCode,
          'scene.add(new THREE.AmbientLight(0x404040,0.5));\n',
          'const d=new THREE.DirectionalLight(0xffffff,1);d.position.set(5,10,5);scene.add(d);\n',
          'function animate(){requestAnimationFrame(animate);renderer.render(scene,camera);}\n',
          'animate();\n',
          '\x3C/script>\n</body>\n</html>'
        ];
        
        const blob = new Blob([htmlParts.join('')], { type: 'text/html' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = title.toLowerCase().replace(/[^a-z0-9]+/g, '-') + '.html';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        
        this.hideExportDialog();
        alert('场景已导出！');
      }
    }

    // 命令类
    class AddObjectCmd {
      constructor(editor, object) {
        this.editor = editor;
        this.object = object;
        this.isLight = object.isLight;
      }
      execute() {}
      undo() {
        this.editor.scene.remove(this.object);
        this.editor.objects = this.editor.objects.filter(o => o !== this.object);
        
        // 如果是灯光，从灯光列表中移除
        if (this.isLight) {
          const lightIndex = this.editor.lights.indexOf(this.object);
          if (lightIndex > -1) {
            this.editor.lights.splice(lightIndex, 1);
          }
          this.editor.updateLightList();
        }
        
        if (this.editor.selected === this.object) {
          this.editor.select(null);
        }
        this.editor.updateTree();
      }
    }

    class TransformCmd {
      constructor(object, oldTransform) {
        this.object = object;
        this.oldPos = oldTransform.position.clone();
        this.oldRot = oldTransform.rotation.clone();
        this.oldScale = oldTransform.scale.clone();
        this.newPos = object.position.clone();
        this.newRot = object.rotation.clone();
        this.newScale = object.scale.clone();
      }
      execute() {
        this.object.position.copy(this.newPos);
        this.object.rotation.copy(this.newRot);
        this.object.scale.copy(this.newScale);
      }
      undo() {
        this.object.position.copy(this.oldPos);
        this.object.rotation.copy(this.oldRot);
        this.object.scale.copy(this.oldScale);
      }
    }

    // FPS 计数器（必须在 Editor 实例化之前声明）
    let frames = 0, last = performance.now();
    
    // 启动
    editor = new Editor();
    window.editor = editor;
    setInterval(() => {
      const now = performance.now();
      document.getElementById('st-fps').textContent = Math.round(frames * 1000 / (now - last)) + ' FPS';
      frames = 0;
      last = now;
    }, 1000);
  </script>
</body>
</html>
